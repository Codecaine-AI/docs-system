    "b-00-local-dev-loop-code-14": {
      "id": "b-00-local-dev-loop-code-14",
      "type": "code",
      "props": {},
      "text": [
        {
          "insert": "# here: commit + push\n# in the consuming repo:\ngit -C tools/docs-framework fetch origin\ngit -C tools/docs-framework checkout origin/main\ngit add tools/docs-framework\ngit commit -m \"chore: bump docs-framework pin\""
        }
      ],
