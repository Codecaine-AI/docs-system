    "b-10-save-pipeline-how-a-save-works-1": {
      "id": "b-10-save-pipeline-how-a-save-works-1",
      "type": "heading",
      "props": {
        "level": 1
      },
      "text": [
        {
          "insert": "How a save works"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-the-full-path-from-a-key-2": {
      "id": "b-10-save-pipeline-the-full-path-from-a-key-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The full path from a keystroke to bytes on disk — worth knowing when\ndebugging, and a good map of how the packages cooperate."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-1-editing-docs-viewer-3": {
      "id": "b-10-save-pipeline-1-editing-docs-viewer-3",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "1. Editing (docs-viewer)"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-doceditor-hosts-a-tipt-4": {
      "id": "b-10-save-pipeline-doceditor-hosts-a-tipt-4",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "DocEditor",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " hosts a TipTap/ProseMirror editor whose node schema mirrors the\ndoc.json block types one-to-one. Every ProseMirror node carries the block's\nstable id in its attrs, so a block edited in place keeps its identity —\nthat is what lets the diff below emit a single "
        },
        {
          "insert": "updateBlock",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " instead of a\ndelete + insert pair."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-2-diff-to-ops-docs-vie-5": {
      "id": "b-10-save-pipeline-2-diff-to-ops-docs-vie-5",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "2. Diff to ops (docs-viewer → docs-model)"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-on-save-debounce-fire-6": {
      "id": "b-10-save-pipeline-on-save-debounce-fire-6",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "On save (debounce fire, "
        },
        {
          "insert": "Cmd+S",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", blur, or unmount), the editor converts its\nProseMirror state back to a "
        },
        {
          "insert": "DocDocument",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and diffs it against the baseline\ndoc this editing session started from. The diff is a minimal batch of the\nmodel's six generic structural/text ops (the vocabulary's seventh op,\n"
        },
        {
          "insert": "blockAction",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", is the typed-action bridge for agents — see below; the\neditor's diff never emits it). A no-op edit diffs to zero ops and no\nrequest is sent."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-3-post-api-ops-docs-w-7": {
      "id": "b-10-save-pipeline-3-post-api-ops-docs-w-7",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "3. POST /api/ops (docs-workbench → docs-server)"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-the-op-batch-is-posted-w-8": {
      "id": "b-10-save-pipeline-the-op-batch-is-posted-w-8",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The op batch is posted with two guards:"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-expected-hash-the-co-9": {
      "id": "b-10-save-pipeline-expected-hash-the-co-9",
      "type": "list-item",
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "expected_hash",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — the content hash of the doc the diff was computed"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-against-mismatch-409-10": {
      "id": "b-10-save-pipeline-against-mismatch-409-10",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "  against. Mismatch → "
        },
        {
          "insert": "409",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", nothing written."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-session-id-the-tab-s-11": {
      "id": "b-10-save-pipeline-session-id-the-tab-s-11",
      "type": "list-item",
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "session_id",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — the tab's identity, checked against the draft lock and"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-used-to-filter-self-echo-12": {
      "id": "b-10-save-pipeline-used-to-filter-self-echo-12",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "  used to filter self-echoes out of the SSE stream."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-on-success-the-server-ap-13": {
      "id": "b-10-save-pipeline-on-success-the-server-ap-13",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "On success the server applies the ops atomically (per-path mutex,\ntemp-then-rename), stores the inverse ops in the undo ledger under a\n"
        },
        {
          "insert": "patch_id",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", broadcasts an SSE change event with the changed block ids, and\nreturns the new doc + hash."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-4-reconciliation-back-14": {
      "id": "b-10-save-pipeline-4-reconciliation-back-14",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "4. Reconciliation (back in the editor)"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-the-editor-adopts-the-se-15": {
      "id": "b-10-save-pipeline-the-editor-adopts-the-se-15",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The editor adopts the server's returned doc as the next diff baseline. The\nhost feeds that same object back down as the "
        },
        {
          "insert": "document",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " prop, and the\neditor recognizes the identity and "
        },
        {
          "insert": "skips",
          "attributes": {
            "italic": true
          }
        },
        {
          "insert": " re-seeding its content — this is\nwhy a save never resets your cursor. If keystrokes landed while the save\nwas in flight, the doc simply stays dirty and the next debounce saves the\nremainder against the new baseline."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-change-flashes-and-prose-16": {
      "id": "b-10-save-pipeline-change-flashes-and-prose-16",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Change flashes and ProseMirror ownership"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-when-an-sse-event-flashe-17": {
      "id": "b-10-save-pipeline-when-an-sse-event-flashe-17",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "When an SSE event flashes changed blocks, the read surfaces get a\n"
        },
        {
          "insert": "data-docs-changed",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " attribute set on the block's wrapper element. Inside\nthe editor that approach cannot work: ProseMirror owns the contenteditable\nDOM and strips foreign attribute mutations as drift. The editor therefore\nrenders the flash as a ProseMirror "
        },
        {
          "insert": "node decoration",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " driven by the same\nhighlighted-id set — same CSS animation, different mechanism."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-one-upload-route-sits-be-19": {
      "id": "b-10-save-pipeline-one-upload-route-sits-be-19",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "One upload route sits beside "
        },
        {
          "insert": "/api/ops",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ": dropping a video file in the\neditor first POSTs it (multipart) to "
        },
        {
          "insert": "POST /api/assets/video",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — a strict\nroute with a 64 MB cap, an extension/MIME allowlist ("
        },
        {
          "insert": "mp4",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "webm",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "mov",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "m4v",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "video/*",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "), and collision-suffixed filenames under the bundle's\n"
        },
        {
          "insert": "assets/videos/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — and only inserts the video block (whose "
        },
        {
          "insert": "props.src",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "\npoints at the stored file) once the upload resolves. A failed upload\ninserts nothing."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-callout-dirty-suppress-20": {
      "id": "b-10-save-pipeline-callout-dirty-suppress-20",
      "type": "callout",
      "props": {
        "tone": "info",
        "kind": "Gotcha",
        "title": "Why didn't the live update apply?"
      },
      "text": [
        {
          "insert": "SSE auto-apply is suppressed while your editor is dirty or a save is in flight — incoming remote changes are held rather than clobbering your unsaved draft. Nothing is lost: once you save (or reload), any true overlap surfaces as the save-time 409 instead of a silent merge."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-typed-block-actions-the-21": {
      "id": "b-10-save-pipeline-typed-block-actions-the-21",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Typed block actions (the seventh op)"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-structured-object-blocks-22": {
      "id": "b-10-save-pipeline-structured-object-blocks-22",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Structured object blocks — code annotations, "
        },
        {
          "insert": "structured-table",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ",\n"
        },
        {
          "insert": "file-tree",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "interaction-surface",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — are edited through named actions\ninstead of hand-built props JSON. A "
        },
        {
          "insert": "blockAction",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " op carries an action name\nplus params; the server resolves it from the registry in\n"
        },
        {
          "insert": "docs-model/src/block-actions.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (13 actions today), validates the\nparams, and expands it into an ordinary "
        },
        {
          "insert": "updateBlock",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " props patch — so\nthe inverse op, the undo ledger, and the SSE broadcast all work exactly as\nabove. Agents discover the whole edit surface (the generic ops plus every\naction's param specs) from "
        },
        {
          "insert": "GET /api/blocks",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Two of the thirteen, as\nsignatures:"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-block-action-examples-23": {
      "id": "b-10-save-pipeline-block-action-examples-23",
      "type": "interaction-surface",
      "props": {
        "title": "blockAction examples (2 of 13)",
        "operations": [
          {
            "name": "structured-table.updateCell",
            "description": "Set one cell, addressing the column by name (column) or position (columnIndex)",
            "params": [
              { "name": "rowIndex", "type": "number", "required": true },
              { "name": "column", "type": "string", "required": false, "description": "exactly one of column/columnIndex" },
              { "name": "columnIndex", "type": "number", "required": false },
              { "name": "value", "type": "string", "required": true }
            ],
            "returns": "updateBlock props patch (standard inverse)",
            "kind": "action"
          },
          {
            "name": "code.setAnnotation",
            "description": "Upsert a line annotation keyed by its exact \"lines\" string",
            "params": [
              { "name": "lines", "type": "string", "required": true, "description": "line range key, e.g. \"4-9\"" },
              { "name": "note", "type": "string", "required": true },
              { "name": "label", "type": "string", "required": false }
            ],
            "returns": "updateBlock props patch (standard inverse)",
            "kind": "action"
          }
        ]
      },
      "children": []
    }
  }
}
