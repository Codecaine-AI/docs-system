    "b-24-canvas-proj-7": {
      "id": "b-24-canvas-proj-7",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "An HTML-comment reference line — "
        },
        {
          "insert": "<!-- canvas: <src> [view=<view>] [title=\"<title>\"] -->",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", or "
        },
        {
          "insert": "<!-- canvas: (missing src) -->",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " when no source is set. Chosen over a markdown image because a canvas is not an image asset; the comment form greps cleanly on "
        },
        {
          "insert": "<!-- canvas:",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " without being misread as a broken image link."
        }
      ],
      "children": []
    },
    "b-24-canvas-actions-h-8": {
