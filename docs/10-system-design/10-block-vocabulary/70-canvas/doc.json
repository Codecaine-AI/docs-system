    "b-24-canvas-actions-note-9": {
      "id": "b-24-canvas-actions-note-9",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Five actions are lifted at module load from "
        },
        {
          "insert": "CANVAS_AGENT_PATCH_OPERATIONS",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " in "
        },
        {
          "insert": "@codecaine-ai/canvas/agent-schema",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — schema truth stays in the canvas package. They carry "
        },
        {
          "insert": "forward: { authority: \"canvas\" }",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " instead of a local "
        },
        {
          "insert": "apply",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ": the dispatcher validates params against the lifted TypeBox schema, then the server forwards the operation to the canvas authority rather than patching doc props."
        }
      ],
      "children": []
    },
    "b-24-canvas-actions-10": {
      "id": "b-24-canvas-actions-10",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "canvas.addObject",
            "description": "Add a fully specified canvas object at its provided geometry; a section requires a nonblank title and known tint.",
            "params": [
              {
                "name": "object",
                "type": "CanvasObject",
                "required": true
              }
            ],
            "returns": "forwarded to the canvas authority"
          },
          {
            "name": "canvas.updateObject",
            "description": "Update an existing canvas object by ID, shallow-merging fields and deep-merging style fields; a resulting section requires a nonblank title and known tint.",
            "params": [
              {
                "name": "objectId",
                "type": "string",
                "required": true
              },
              {
                "name": "patch",
                "type": "object",
                "required": true
              }
            ],
            "returns": "forwarded to the canvas authority"
          },
          {
            "name": "canvas.addConnection",
            "description": "Add a canvas connection with explicit endpoint object IDs and optional routing metadata.",
            "params": [
              {
                "name": "connection",
                "type": "CanvasConnection",
                "required": true
              }
            ],
            "returns": "forwarded to the canvas authority"
          },
          {
            "name": "canvas.addAnnotation",
            "description": "Add an annotation targeting a canvas object, connection, or region.",
            "params": [
              {
                "name": "annotation",
                "type": "CanvasAnnotation",
                "required": true
              }
            ],
            "returns": "forwarded to the canvas authority"
          },
          {
            "name": "canvas.fitContainerToChildren",
            "description": "Resize a container to enclose its current child objects with optional padding.",
            "params": [
              {
                "name": "containerId",
                "type": "string",
                "required": true
              },
              {
                "name": "padding",
                "type": "number",
                "required": false
              }
            ],
            "returns": "forwarded to the canvas authority"
          }
        ],
        "title": "canvas — forwarded patch operations"
      },
      "children": []
    },
