    "b-24-canvas-lead-2": {
      "id": "b-24-canvas-lead-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The spatial-canvas block of the "
        },
        {
          "insert": "block vocabulary",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "docs/10-system-design/10-block-vocabulary/00-overview.md",
              "label": "block vocabulary"
            }
          }
        },
        {
          "insert": ". The block itself is only a reference — the canvas document, its objects, and its schema live in the external canvas system ("
        },
        {
          "insert": "external/canvas",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", the vendored sibling project); the doc block points at one and optionally crops it to a named view."
        }
      ],
      "children": []
    },
