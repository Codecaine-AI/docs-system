    "b-20-block-vocabulary-agents-read-docs-2": {
      "id": "b-20-block-vocabulary-agents-read-docs-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "These docs are written primarily for "
        },
        {
          "insert": "agents",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " to read. The markdown projection ("
        },
        {
          "insert": "projectToMarkdown",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " in docs-model, served at "
        },
        {
          "insert": "GET /api/markdown",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and driving the "
        },
        {
          "insert": "docs render",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " / "
        },
        {
          "insert": "docs grep",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " CLI) is the primary consumer: every block type defines a deterministic, greppable markdown form, so an agent never has to parse "
        },
        {
          "insert": "doc.json",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " just to read a document. The workbench renders the human view from the same blocks."
        }
