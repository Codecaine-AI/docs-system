    "b-20-block-vocabulary-tree-actions-19": {
      "id": "b-20-block-vocabulary-tree-actions-19",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "file-tree.addEntry",
            "description": "Append a path entry (optional note and change marker) to the file tree.",
            "params": [
              {
                "name": "path",
                "type": "string",
                "required": true,
                "description": "/-separated path, no leading \"./\"; a trailing \"/\" marks an explicit directory."
              },
              {
                "name": "note",
                "type": "string",
                "required": false,
                "description": "Short annotation rendered after the path."
              },
              {
                "name": "change",
                "type": "string",
                "required": false,
                "description": "Change marker: \"added\" | \"removed\" | \"modified\" | \"renamed\"."
              }
            ],
            "returns": "props patch: { entries }"
          },
          {
            "name": "file-tree.removeEntry",
            "description": "Remove the entry with the given path from the file tree.",
            "params": [
              {
                "name": "path",
                "type": "string",
                "required": true,
                "description": "Exact path of the entry to remove."
              }
            ],
            "returns": "props patch: { entries }"
          },
          {
            "name": "file-tree.updateEntry",
            "description": "Patch an entry's note/change/from, or rename it via newPath (in place).",
            "params": [
              {
                "name": "path",
                "type": "string",
                "required": true,
                "description": "Exact path of the entry to patch."
              },
              {
                "name": "note",
                "type": "string",
                "required": false,
                "description": "New note; pass null to clear."
              },
              {
                "name": "change",
                "type": "string",
                "required": false,
                "description": "New change marker; pass null to clear."
              },
              {
                "name": "from",
                "type": "string",
                "required": false,
                "description": "Previous path (for renamed); pass null to clear."
              },
              {
                "name": "newPath",
                "type": "string",
                "required": false,
