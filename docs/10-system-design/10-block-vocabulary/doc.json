        {
          "insert": "fourteen block types, and no more",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": ". A small vocabulary keeps the projection stable, the editor learnable, and the agent edit surface enumerable. For documenting agentic systems, two of those types carry the whole model:"
        }
      ],
      "children": []
    },
