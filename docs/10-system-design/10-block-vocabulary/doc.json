    "b-20-block-vocabulary-code-actions-15": {
      "id": "b-20-block-vocabulary-code-actions-15",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "code.setAnnotation",
            "description": "Upsert a line annotation keyed by its exact \"lines\" string (e.g. \"4-9\").",
            "params": [
              {
                "name": "lines",
                "type": "string",
                "required": true,
                "description": "Line range key, e.g. \"1\" or \"4-9\"."
              },
              {
                "name": "note",
                "type": "string",
                "required": true,
                "description": "Annotation body."
              },
              {
                "name": "label",
                "type": "string",
                "required": false,
                "description": "Optional short label."
              }
            ],
            "returns": "props patch: { annotations }"
          },
          {
            "name": "code.removeAnnotation",
            "description": "Remove the annotation whose \"lines\" key matches exactly.",
            "params": [
              {
                "name": "lines",
                "type": "string",
                "required": true,
                "description": "Line range key of the annotation."
              }
            ],
            "returns": "props patch: { annotations }"
          }
        ],
        "title": "code — annotation actions (source text stays on generic ops)"
      },
      "children": []
    },
    "b-20-block-vocabulary-table-actions-h-16": {
