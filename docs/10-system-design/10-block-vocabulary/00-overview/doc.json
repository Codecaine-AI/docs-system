    "b-00-vocab-overview-actions-18": {
      "id": "b-00-vocab-overview-actions-18",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Every bundle supplies a manifest, closed TypeBox state schemas with a per-type "
        },
        {
          "insert": "carriesText",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " fact, one file per action verb, and an "
        },
        {
          "insert": "agent-view.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " markdown projection. Four bundles expose 13 typed actions — code (2), structured-table (5), file-tree (3), interaction-surface (3) — and canvas forwards 5 more to the external canvas authority. Actions ride the generic op kernel as "
        },
        {
          "insert": "blockAction",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " ops; the kernel, hash preconditions, and undo are the "
        },
        {
          "insert": "mutation model",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "docs/10-system-design/20-mutation-model.md",
              "label": "mutation model"
            }
          }
        },
        {
          "insert": "'s story, not this one. The per-type pages document each block's actions where they exist."
        }
