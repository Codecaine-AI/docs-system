    "b-20-mutation-model-change-events-sse-16": {
      "id": "b-20-mutation-model-change-events-sse-16",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "A successful apply broadcasts an SSE change event carrying the ids of blocks whose content or placement changed. Consumers use that id set to flash the affected blocks; the event is a notification of the applied patch, not a second write path."
        }
      ],
      "children": []
    },
    "b-20-mutation-model-dirty-suppression-17": {
      "id": "b-20-mutation-model-dirty-suppression-17",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Auto-apply of incoming change events is held while a consumer has an unsaved or dirty draft. Remote changes therefore never clobber local work; if both sides touched overlapping state, the overlap appears as the "
        },
        {
          "insert": "409",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " when the dirty draft is saved against its stale "
        },
        {
          "insert": "expected_hash",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "."
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-callout-dirty-suppress-20": {
      "id": "b-10-save-pipeline-callout-dirty-suppress-20",
      "type": "callout",
      "props": {
        "kind": "Gotcha",
        "title": "Why didn't the live update apply?",
        "tone": "info"
      },
      "text": [
        {
          "insert": "SSE auto-apply is suppressed while your editor is dirty or a save is in flight — incoming remote changes are held rather than clobbering your unsaved draft. Nothing is lost: once you save (or reload), any true overlap surfaces as the save-time 409 instead of a silent merge."
        }
      ],
      "children": []
    },
    "b-20-mutation-model-discovery-18": {
