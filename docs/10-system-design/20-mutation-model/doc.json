    "b-20-mutation-model-discovery-surface-19": {
      "id": "b-20-mutation-model-discovery-surface-19",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "GET /api/blocks",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " exposes the complete edit surface: the seven generic ops plus each block type's named actions, param specs, and descriptions. Agents use it as the contract for writing, so they do not infer structured props from rendered markdown or hand-edit arbitrary JSON."
        }
      ],
      "children": []
