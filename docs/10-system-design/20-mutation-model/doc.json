        }
      ],
      "children": []
    },
    "b-10-save-pipeline-structured-object-blocks-22": {
      "id": "b-10-save-pipeline-structured-object-blocks-22",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Structured object blocks — code annotations, "
        },
        {
          "insert": "structured-table",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "file-tree",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "interaction-surface",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — are edited through named actions instead of hand-built props JSON. A "
        },
        {
          "insert": "blockAction",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " op carries an action name plus params; the action registry validates the params and expands the action into an ordinary "
        },
        {
          "insert": "updateBlock",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " props patch. That means inverse ops, the undo ledger, and change events all work through the same mutation path as generic edits. Agents discover the whole edit surface (the generic ops plus every action's param specs) from "
        },
        {
          "insert": "GET /api/blocks",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Two of the thirteen, as signatures:"
        }
      ],
      "children": []
    },
    "b-10-save-pipeline-block-action-examples-23": {
      "id": "b-10-save-pipeline-block-action-examples-23",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "structured-table.updateCell",
            "description": "Set one cell, addressing the column by name (column) or position (columnIndex)",
            "params": [
              {
                "name": "rowIndex",
                "type": "number",
                "required": true
              },
              {
                "name": "column",
