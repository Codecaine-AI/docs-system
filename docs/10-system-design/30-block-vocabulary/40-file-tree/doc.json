              {
                "name": "path",
                "type": "string",
                "required": true
              },
              {
                "name": "note",
                "type": "string",
                "required": false
              },
              {
                "name": "change",
                "type": "string",
                "required": false
              }
            ],
            "returns": "props patch: { entries }"
          },
          {
            "name": "file-tree.removeEntry",
            "description": "Remove the entry with the given path from the file tree.",
            "params": [
              {
                "name": "path",
                "type": "string",
                "required": true
              }
            ],
            "returns": "props patch: { entries }"
          },
          {
            "name": "file-tree.updateEntry",
            "description": "Patch an entry's note/change/from, or rename it via newPath (in place).",
            "params": [
              {
                "name": "path",
                "type": "string",
                "required": true
              },
              {
                "name": "note",
                "type": "string | null",
                "required": false
              },
              {
                "name": "change",
                "type": "string | null",
                "required": false
              },
              {
                "name": "from",
                "type": "string | null",
                "required": false
              },
              {
                "name": "newPath",
                "type": "string",
                "required": false
              }
            ],
            "returns": "props patch: { entries }"
          }
        ],
        "title": "file-tree — entry actions"
