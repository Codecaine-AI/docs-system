    "b-21-file-tree-proj-8": {
      "id": "b-21-file-tree-proj-8",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "An optional "
        },
        {
          "insert": "**<title>**",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " bold line, then a literal tree rendering inside a bare fence: "
        },
        {
          "insert": "├──",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "└──",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "│",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " guides, directories first then alphabetical (deterministic codepoint order), notes appended as "
        },
        {
          "insert": "# note",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Change markers prefix the line — "
        },
        {
          "insert": "+",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " added, "
        },
        {
          "insert": "-",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " removed, "
        },
        {
          "insert": "~",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " modified, "
        },
        {
          "insert": ">",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " renamed (rendered as "
        },
        {
          "insert": "{from} -> {name}",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ") — and when any entry carries a marker, unmarked lines are padded with two spaces so the guides stay aligned."
        }
      ],
      "children": []
    },
