      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The typed table of the "
        },
        {
          "insert": "block vocabulary",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/30-block-vocabulary/00-overview",
              "label": "block vocabulary"
            }
          }
        },
        {
          "insert": ": a columns × rows grid of strings kept in props, not prose. Use it for index tables, comparison matrices, and anything an agent should edit cell-by-cell instead of re-flowing text."
        }
      ],
      "children": []
    },
