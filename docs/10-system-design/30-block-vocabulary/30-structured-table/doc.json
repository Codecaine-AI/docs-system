    "b-20-structured-table-state-4": {
      "id": "b-20-structured-table-state-4",
      "type": "structured-table",
      "props": {
        "columns": [
          "prop",
          "type",
          "required",
          "notes"
        ],
        "rows": [
          [
            "title",
            "string",
            "no",
            "Optional bold caption above the table."
          ],
          [
            "columns",
            "string[]",
            "yes",
            "Header names, in order."
          ],
          [
            "rows",
            "string[][]",
            "yes",
            "One string array per row; actions normalize each row to the column count."
          ],
          [
            "density",
