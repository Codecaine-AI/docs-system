      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "An optional "
        },
        {
          "insert": "**<title>**",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " bold line, then a markdown pipe table: header row, "
        },
        {
          "insert": "---",
          "attributes": {
            "code": true
          }
        },
        {
