    "b-20-structured-table-state-note-5": {
      "id": "b-20-structured-table-state-note-5",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "No text ("
        },
        {
          "insert": "carriesText: false",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ") — the whole block is typed props. Cells are plain strings: no marks, no reference chips inside a table."
        }
      ],
      "children": []
    },
