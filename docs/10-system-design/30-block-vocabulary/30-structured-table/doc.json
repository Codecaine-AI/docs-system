    "b-20-structured-table-actions-note-9": {
      "id": "b-20-structured-table-actions-note-9",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Five actions cover the grid. Column addressing accepts exactly one of "
        },
        {
          "insert": "column",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (by name) or "
        },
        {
          "insert": "columnIndex",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (by position); "
        },
        {
          "insert": "addColumn",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " rejects a duplicate name and back-fills existing rows with "
        },
        {
          "insert": "fill",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (default empty string); row inserts default to the end and pad or truncate "
        },
        {
          "insert": "cells",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " to the column count."
        }
      ],
      "children": []
    },
    "b-20-structured-table-actions-10": {
      "id": "b-20-structured-table-actions-10",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "structured-table.addRow",
            "description": "Insert a row (cells padded/truncated to the column count); index defaults to the end.",
            "params": [
              {
                "name": "cells",
                "type": "string[]",
                "required": true
              },
              {
                "name": "index",
                "type": "number",
                "required": false
              }
            ],
            "returns": "props patch: { rows }"
          },
          {
            "name": "structured-table.removeRow",
            "description": "Remove the row at the given index.",
            "params": [
              {
                "name": "index",
                "type": "number",
                "required": true
              }
            ],
            "returns": "props patch: { rows }"
          },
          {
            "name": "structured-table.updateCell",
            "description": "Set one cell, addressing the column by name (column) or position (columnIndex).",
            "params": [
              {
                "name": "rowIndex",
                "type": "number",
                "required": true
              },
              {
                "name": "column",
                "type": "string",
                "required": false
              },
              {
                "name": "columnIndex",
                "type": "number",
                "required": false
              },
              {
                "name": "value",
                "type": "string",
                "required": true
              }
            ],
            "returns": "props patch: { rows }"
          },
          {
            "name": "structured-table.addColumn",
            "description": "Insert a column (default at the end), extending every row with the fill value.",
            "params": [
              {
                "name": "name",
                "type": "string",
                "required": true
              },
              {
                "name": "index",
                "type": "number",
                "required": false
              },
              {
                "name": "fill",
                "type": "string",
                "required": false
              }
            ],
            "returns": "props patch: { columns, rows }"
          },
          {
            "name": "structured-table.removeColumn",
            "description": "Remove a column by name (column) or position (columnIndex), shrinking every row.",
            "params": [
              {
                "name": "column",
                "type": "string",
                "required": false
              },
              {
                "name": "columnIndex",
                "type": "number",
                "required": false
              }
            ],
            "returns": "props patch: { columns, rows }"
          }
        ],
        "title": "structured-table — row and column actions"
      },
      "children": []
    },
