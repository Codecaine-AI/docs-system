        "level": 2
      },
      "text": [
        {
          "insert": "The \"Why\" Travels with Every Decision"
        }
      ],
      "children": []
    },
    "b-da3-why-para-11": {
      "id": "b-da3-why-para-11",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Every decision in these docs carries its why"
        }
      ],
      "children": []
    },
    "pm-mruq0c12-108-dfykqf": {
      "id": "pm-mruq0c12-108-dfykqf",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "The what can be re-derived from the system; the why cannot"
        }
      ],
      "children": []
    },
    "pm-mruq0c12-109-0j73yx": {
      "id": "pm-mruq0c12-109-0j73yx",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Recorded, it does two jobs"
        }
      ],
      "children": [
        "pm-mruq0c12-110-6eqeyi",
        "pm-mruq0c12-111-fquofo"
      ]
    },
    "pm-mruq0c12-110-6eqeyi": {
      "id": "pm-mruq0c12-110-6eqeyi",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "A returning human sees exactly why a choice was made a month ago and easily re-onboard to the project"
        }
      ],
      "children": []
    },
    "pm-mruq0c12-111-fquofo": {
      "id": "pm-mruq0c12-111-fquofo",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "An agent checking its work against the docs cannot overturn deliberate intent by accident"
        }
      ],
      "children": []
    },
