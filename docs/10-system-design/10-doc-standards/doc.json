    "b-da3-title-1": {
      "id": "b-da3-title-1",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Documentation defines what a system should do without the code. "
        }
      ],
      "children": []
    },
    "b-da3-scale-lead-3": {
      "id": "b-da3-scale-lead-3",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The structure defined in these standards is built for many agents at once. "
        }
      ],
      "children": []
    },
    "pm-mruq0c12-107-u8o42s": {
      "id": "pm-mruq0c12-107-u8o42s",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "With 10, 20, or 100+ agents working a codebase, every change needs one canonical place to land"
        }
      ],
      "children": []
    },
    "b-da3-layers-heading-7": {
      "id": "b-da3-layers-heading-7",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "The Three Layers"
        }
      ],
      "children": []
    },
