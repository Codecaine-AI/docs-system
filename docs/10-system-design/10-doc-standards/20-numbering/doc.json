        {
          "insert": "Why"
        }
      ],
      "children": []
    },
    "b-nwhy-human-1": {
      "id": "b-nwhy-human-1",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Ordered for human reading",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "b-nwhy-human-1-sub",
        "b-nwhy-human-sub1-2"
      ]
    },
    "b-nwhy-human-1-sub": {
      "id": "b-nwhy-human-1-sub",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "The numbers are for people first."
        }
      ],
      "children": []
    },
    "b-nwhy-human-sub1-2": {
      "id": "b-nwhy-human-sub1-2",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Prefixes put reading order in the filesystem itself — sidebar, terminal, and render agree without a manifest."
        }
      ],
      "children": []
    },
    "b-num-why-local-18": {
      "id": "b-num-why-local-18",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Insertion is local",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "pm-mruqahhh-23-2v0bj8"
      ]
    },
    "pm-mruqahhh-23-2v0bj8": {
      "id": "pm-mruqahhh-23-2v0bj8",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "A new doc lands mid-gap and nothing else moves, which matters when paths are reference targets."
        }
      ],
      "children": []
    },
    "b-nwhy-agent-3": {
      "id": "b-nwhy-agent-3",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "A clean search path for agents",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "b-nwhy-agent-3-sub",
        "b-nwhy-agent-sub1-4"
      ]
    },
    "b-nwhy-agent-3-sub": {
      "id": "b-nwhy-agent-3-sub",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Second to human reading, and just as real."
        }
      ],
      "children": []
    },
    "b-nwhy-agent-sub1-4": {
      "id": "b-nwhy-agent-sub1-4",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "The same explicit order tells an agent where to search and where to land a change — structure instead of hand-waving."
        }
      ],
      "children": []
    },
    "b-num-why-exhaust-19": {
      "id": "b-num-why-exhaust-19",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Exhaustion is a signal",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "pm-mruqahhh-24-8u667j"
      ]
    },
    "pm-mruqahhh-24-8u667j": {
      "id": "pm-mruqahhh-24-8u667j",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "The moment you cannot number a doc, the section needs a subfolder. Packing consecutive numbers silences that signal."
        }
      ],
      "children": []
    }
  }
