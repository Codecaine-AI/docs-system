      "children": []
    },
    "b-num-rule-heading-2": {
      "id": "b-num-rule-heading-2",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "The Rule"
        }
      ],
      "children": []
    },
    "b-num-rule-prefix-3": {
      "id": "b-num-rule-prefix-3",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Prefix every doc and directory with two digits and a hyphen: "
        },
        {
          "insert": "XX-lowercase-hyphenated-name",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "."
        }
      ],
      "children": []
    },
    "b-num-rule-gap-4": {
      "id": "b-num-rule-gap-4",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Leave gaps of ten ("
        },
        {
          "insert": "10-",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "20-",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "30-",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ") so a new doc can be inserted without renumbering anything."
        }
      ],
      "children": []
    },
    "b-num-rule-midgap-5": {
      "id": "b-num-rule-midgap-5",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Insert mid-gap first — "
        },
        {
          "insert": "25-",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " between "
        },
        {
          "insert": "20-",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and "
        },
        {
          "insert": "30-",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — before considering any reorganization."
        }
      ],
      "children": []
    },
    "b-num-rule-exhaust-6": {
      "id": "b-num-rule-exhaust-6",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "When the gaps are exhausted, the number line is telling you the section has outgrown its shape: reorganize into a subfolder rather than packing consecutive numbers."
        }
      ],
      "children": []
    },
    "b-num-rule-table-7": {
      "id": "b-num-rule-table-7",
      "type": "structured-table",
      "props": {
        "columns": [
          "Range    ",
          "Reserved for"
        ],
        "rows": [
          [
            "00–09",
            "Early or foundational content, used sparingly — 00 is a plain sort prefix, not a reserved slot; new sections start children at 10"
          ],
          [
            "10–89",
            "Main content"
          ],
          [
            "90–98",
            "Late or supplementary content"
          ],
          [
            "99",
            "Appendix and meta (20-implementation/99-appendix/)"
          ]
        ]
      },
      "children": []
    },
    "b-num-rule-anti-8": {
      "id": "b-num-rule-anti-8",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Violations look like: consecutive numbers with no gaps, mixed formats ("
        },
        {
          "insert": "1-intro",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "02-setup",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "section-3",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "), "
        },
        {
          "insert": "99-",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " on anything but appendix material."
        }
      ],
      "children": []
    },
    "b-num-why-heading-12": {
      "id": "b-num-why-heading-12",
      "type": "heading",
      "props": {
        "level": 2
      },
