      "text": [
        {
          "insert": "{\n  \"insert\": \"structure\",\n  \"attributes\": {\n    \"reference\": {\n      \"kind\": \"doc\",\n      \"path\": \"10-system-design/10-doc-standards/10-structure\"\n    }\n  }\n}"
        }
      ],
      "children": []
