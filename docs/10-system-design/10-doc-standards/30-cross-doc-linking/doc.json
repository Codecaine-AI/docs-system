    "b-xl2-intro-1": {
      "id": "b-xl2-intro-1",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Docs link to docs with typed reference spans — tracked by the backlinks index, held at zero stale, rewritten when targets move — never with raw paths in prose. "
        }
      ],
      "children": []
    },
    "pm-mrurzsxw-1-g0jett": {
      "id": "pm-mrurzsxw-1-g0jett",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "This page states the reference object, which directions links run, and the restraint rules against overlinking."
        }
      ],
      "children": []
    },
    "b-xl2-laidout-h-2": {
      "id": "b-xl2-laidout-h-2",
