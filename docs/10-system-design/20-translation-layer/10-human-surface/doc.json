    "b-hsurf-intro-1": {
      "id": "b-hsurf-intro-1",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "A human meets a document as a Notion-style editor: rich blocks, direct manipulation, annotations, live theming. "
        }
      ],
      "children": []
    },
    "pm-mrusl6tk-2-qlyv2s": {
      "id": "pm-mrusl6tk-2-qlyv2s",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "This page states what the surface owes a human reader and how a human's edits reach the shared state."
        }
      ],
      "children": []
    },
    "b-hsurf-read-h-2": {
      "id": "b-hsurf-read-h-2",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Reading"
        }
      ],
      "children": []
    },
    "b-hsurf-read-blocks-3": {
      "id": "b-hsurf-read-blocks-3",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Blocks render as rich components"
        }
      ],
      "children": [
        "b-hsurf-read-blocks-3-gloss"
      ]
    },
    "b-hsurf-read-blocks-3-gloss": {
      "id": "b-hsurf-read-blocks-3-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Tables, canvases, annotated code, file trees — not walls of text."
        }
      ],
      "children": []
    },
    "b-hsurf-read-title-4": {
      "id": "b-hsurf-read-title-4",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "The page title is furniture derived from the doc's name; the sidebar walks the numbered tree in reading order."
        }
      ],
      "children": []
    },
    "b-hsurf-edit-h-5": {
      "id": "b-hsurf-edit-h-5",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Editing"
        }
      ],
      "children": []
    },
    "b-hsurf-edit-typing-6": {
      "id": "b-hsurf-edit-typing-6",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Typing follows Notion semantics"
        }
      ],
      "children": [
        "b-hsurf-edit-typing-6-gloss"
      ]
    },
    "b-hsurf-edit-typing-6-gloss": {
      "id": "b-hsurf-edit-typing-6-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Enter, backspace, markdown shortcuts, and the slash menu behave the way a Notion user expects."
        }
      ],
      "children": []
    },
    "b-hsurf-edit-direct-7": {
      "id": "b-hsurf-edit-direct-7",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Direct manipulation: a drag grip on every block, band selection from the margins, structure-preserving copy and paste."
        }
      ],
      "children": []
    },
    "b-hsurf-edit-comments-8": {
      "id": "b-hsurf-edit-comments-8",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Annotations anchor to blocks and to text spans."
        }
      ],
      "children": []
    },
    "b-hsurf-edit-ops-9": {
      "id": "b-hsurf-edit-ops-9",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "No edit touches the file. Every change the surface makes lands as a typed operation against the canonical state — the "
        },
        {
          "insert": "mutation model",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/30-data-model/50-mutation-model"
            }
          }
        },
        {
          "insert": " defines them."
        }
      ],
      "children": []
    },
    "b-hsurf-theme-h-10": {
      "id": "b-hsurf-theme-h-10",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Theming and embedding"
        }
      ],
      "children": []
    },
    "b-hsurf-theme-tokens-11": {
      "id": "b-hsurf-theme-tokens-11",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "The surface is themable through an open token contract — colors, fonts, spacing — and the theme evolves live while editing."
        }
      ],
      "children": []
    },
    "b-hsurf-theme-embed-12": {
      "id": "b-hsurf-theme-embed-12",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "It is embeddable: the same editor serves the workbench and any host that wants the docs in place."
        }
      ],
      "children": []
    },
    "b-hsurf-why-h-13": {
      "id": "b-hsurf-why-h-13",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Why"
        }
      ],
      "children": []
    },
    "b-hsurf-why-visual-14": {
      "id": "b-hsurf-why-visual-14",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Humans learn visually",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "b-hsurf-why-visual-sub-15"
      ]
    },
    "b-hsurf-why-visual-sub-15": {
      "id": "b-hsurf-why-visual-sub-15",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Rich components and layout carry more than text alone; the reading surface uses them everywhere it can."
        }
      ],
      "children": []
    },
    "b-hsurf-why-pen-16": {
      "id": "b-hsurf-why-pen-16",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "The editor is the only pen",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "b-hsurf-why-pen-sub1-17",
        "b-hsurf-why-pen-sub2-18"
      ]
    },
    "b-hsurf-why-pen-sub1-17": {
      "id": "b-hsurf-why-pen-sub1-17",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "A human never edits bytes; the surface turns intent into typed operations."
        }
      ],
      "children": []
    },
    "b-hsurf-why-pen-sub2-18": {
      "id": "b-hsurf-why-pen-sub2-18",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "That is what keeps a human's edits and an agent's edits the same kind of change."
        }
      ],
      "children": []
    }
