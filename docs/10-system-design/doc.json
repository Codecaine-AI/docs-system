    "b-sdov-opener": {
      "id": "b-sdov-opener",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "System design defines the contracts for organizing documentation, rendering canonical document state, mutating block trees, and presenting the workbench. Its five sections separate corpus rules, reader surfaces, state structure, canonical content types, and editor behavior."
        }
      ],
      "children": []
    },
