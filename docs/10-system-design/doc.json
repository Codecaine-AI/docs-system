          "insert": "Docs Architecture"
        }
      ],
      "children": []
    },
    "b-sdov-docarch-p-3": {
      "id": "b-sdov-docarch-p-3",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Documentation is divided into three layers so each piece of knowledge has one canonical home."
        }
      ],
      "children": []
    },
    "pm-mrtq81uh-19-qu48f4": {
      "id": "pm-mrtq81uh-19-qu48f4",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Each change lands in the layer that owns its rationale."
        }
      ],
      "children": []
    },
