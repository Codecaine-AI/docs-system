          "insert": " cannot be bundled there. Its database at "
        },
        {
          "insert": "<docsRoot>/.index/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is derived, gitignored, and rebuildable with "
        },
        {
          "insert": "docs backlinks rescan",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "; keeping index separate from server is a judgment call."
