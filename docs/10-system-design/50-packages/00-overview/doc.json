      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "docs-model is forced",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": ": browser, Bun server, and CLI must share one definition of "
        },
        {
          "insert": "doc.json",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Keeping that definition pure TypeScript — without React, filesystem, or network access — makes it portable to all three."
        }
      ],
      "children": []
