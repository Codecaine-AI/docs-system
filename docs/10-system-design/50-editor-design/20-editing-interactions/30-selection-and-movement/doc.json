        }
      ],
      "children": []
    },
    "b-selm-grip-decision": {
      "id": "b-selm-grip-decision",
      "type": "callout",
      "props": {
        "kind": "Decision",
        "title": "Native Drag Handoff",
        "tone": "decision"
      },
      "text": [
        {
          "insert": "The hover grip owns block pickup, then hands a single block's selection and dragged slice to native ProseMirror movement. The editor adds the top-level drop clamp and selected-run move."
        }
      ],
      "children": []
    },
