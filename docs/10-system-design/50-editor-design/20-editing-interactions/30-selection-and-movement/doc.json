    "b-selm-why-top-level-gloss": {
      "id": "b-selm-why-top-level-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Movement and paste retain block boundaries instead of fitting a copied run into another block's child slot."
        }
      ],
      "children": []
    }
  }
