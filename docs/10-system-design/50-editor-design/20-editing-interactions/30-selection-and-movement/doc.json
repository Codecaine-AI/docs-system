    },
    "b-selm-why-whitespace-gloss": {
      "id": "b-selm-why-whitespace-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Margins, gaps, and line run-out expose block selection without taking text selection or embedded interactions away from their owners."
        }
      ],
      "children": []
    },
    "b-selm-why-one-selection": {
      "id": "b-selm-why-one-selection",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "One selection model preserves trust",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "b-selm-why-one-selection-gloss"
      ]
    },
    "b-selm-why-one-selection-gloss": {
      "id": "b-selm-why-one-selection-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "The highlight, clipboard, deletion, and Escape all address the same range, so visible selection never disagrees with the next command."
        }
      ],
      "children": []
    },
    "b-selm-why-top-level": {
      "id": "b-selm-why-top-level",
