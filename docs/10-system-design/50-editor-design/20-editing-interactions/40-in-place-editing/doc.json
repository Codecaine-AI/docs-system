        {
          "insert": "code",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/40-block-vocabulary/20-code-block"
            }
          }
        },
        {
          "insert": " node view establishes the text pattern: its content remains editable by the outer editor while the block supplies its own in-place controls."
        }
      ],
      "children": []
    },
    "b-inpl-table": {
      "id": "b-inpl-table",
      "type": "list-item",
