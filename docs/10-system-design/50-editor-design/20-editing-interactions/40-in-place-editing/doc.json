    "b-inpl-fallback-gloss": {
      "id": "b-inpl-fallback-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Types without a custom node view render their current state as read-only atoms without local editing controls."
        }
      ],
      "children": []
    },
    "b-inpl-fallback-actions": {
      "id": "b-inpl-fallback-actions",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Their state changes through "
        },
