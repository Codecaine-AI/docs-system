              "kind": "doc",
              "path": "10-system-design/30-data-model/20-block-design/20-typed-actions"
            }
          }
        },
        {
          "insert": " until the type deliberately earns an editable node view."
        }
      ],
      "children": []
    },
    "b-inpl-open-call": {
      "id": "b-inpl-open-call",
      "type": "callout",
      "props": {
        "kind": "Open call",
        "title": "Which Object Blocks Require Editable Node Views?",
        "tone": "info"
      },
      "text": [
        {
          "insert": "No general policy determines which object types must support in-place editing. Each type needs a deliberate decision; the shared read-only atom view remains the fallback."
        }
      ],
      "children": []
    },
