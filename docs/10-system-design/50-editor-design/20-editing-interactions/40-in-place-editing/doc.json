    "b-inpl-rendered-gloss": {
      "id": "b-inpl-rendered-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "An editable object keeps its rendered form in the document and reveals its controls in place."
        }
      ],
      "children": []
    },
    "b-inpl-code": {
      "id": "b-inpl-code",
