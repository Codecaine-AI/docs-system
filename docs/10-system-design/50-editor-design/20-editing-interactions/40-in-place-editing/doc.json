    },
    "b-inpl-why-context-gloss": {
      "id": "b-inpl-why-context-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "In-place controls preserve the object's position and its surrounding explanation while it changes."
        }
      ],
      "children": []
    },
    "b-inpl-why-history": {
      "id": "b-inpl-why-history",
      "type": "list-item",
      "props": {},
