      "id": "b-inpl-table-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "The "
        },
        {
          "insert": "structured-table",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/40-block-vocabulary/30-structured-table"
            }
          }
        },
        {
          "insert": " node view places a mini rich-text editor in each cell, but undo and redo remain document-level."
        }
      ],
      "children": []
    },
    "b-inpl-table-detail": {
      "id": "b-inpl-table-detail",
      "type": "list-item",
      "props": {},
