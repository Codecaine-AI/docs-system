    "b-inpl-intro": {
      "id": "b-inpl-intro",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Object blocks edit inside the surface where they render; no modal editor replaces the document context. Custom node views add block-specific editing while the outer editor keeps structural authority. This page defines that shared pattern and the read-only fallback for types without it."
        }
      ],
      "children": []
    },
    "b-inpl-structure-heading": {
      "id": "b-inpl-structure-heading",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Structure"
        }
      ],
      "children": []
    },
    "b-inpl-pattern-table": {
      "id": "b-inpl-pattern-table",
      "type": "structured-table",
      "props": {
        "columns": [
          "Pattern",
          "Outer Editor",
          "Inside the Block"
        ],
        "rows": [
          [
            "Editable text node view",
            "Owns block position, selection, and history",
            "Edits the block's text and local controls"
          ],
          [
            "Editable atom node view",
            "Treats the whole block as one structural leaf",
            "Owns focused editing islands and writes block state back"
          ],
          [
            "Read-only atom view",
            "Treats the whole block as one structural leaf",
            "Renders current state without an in-place editor"
          ]
        ]
      },
      "children": []
    },
    "b-inpl-rule-heading": {
      "id": "b-inpl-rule-heading",
      "type": "heading",
