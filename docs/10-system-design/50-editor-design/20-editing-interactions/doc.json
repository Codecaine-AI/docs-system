      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Editing is the default human surface: every document is always editable, with no separate read mode and no save button. Changes autosave through "
        },
        {
          "insert": "The save pipeline: keystroke to disk",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "20-implementation/30-save-pipeline"
            }
          }
        },
        {
          "insert": " after they become typed operations. This section defines the interaction contract for typing, insertion, structural selection, movement, and object editing."
        }
      ],
      "children": []
    },
