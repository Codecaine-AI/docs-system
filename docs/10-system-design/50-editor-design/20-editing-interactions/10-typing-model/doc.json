    },
    "b-typm-why-owned": {
      "id": "b-typm-why-owned",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Component ownership",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "b-typm-why-owned-gloss"
      ]
    },
    "b-typm-why-owned-gloss": {
      "id": "b-typm-why-owned-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Block design",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/30-data-model/20-block-design"
            }
          }
        },
        {
          "insert": " keeps schema-aware conversion rules with their component, so a shortcut cannot create a structurally invalid block."
        }
      ],
      "children": []
    },
    "b-typm-why-visual": {
      "id": "b-typm-why-visual",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Visual adjacency",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "b-typm-why-visual-gloss"
      ]
    },
    "b-typm-why-visual-gloss": {
      "id": "b-typm-why-visual-gloss",
      "type": "list-item",
      "props": {},
