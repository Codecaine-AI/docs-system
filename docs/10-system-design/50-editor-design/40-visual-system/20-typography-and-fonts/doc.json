    "b-typo-stack-rule": {
      "id": "b-typo-stack-rule",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "System Sans resolves to "
        },
        {
          "insert": "ui-sans-serif, system-ui, sans-serif",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Mono resolves to "
        },
        {
          "insert": "ui-monospace, \"SF Mono\", SFMono-Regular, Menlo, monospace",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Numeric emits no separate family while it follows body."
        }
      ],
      "children": []
