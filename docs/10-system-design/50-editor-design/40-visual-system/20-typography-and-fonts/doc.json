    "b-typo-controls": {
      "id": "b-typo-controls",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The style rail exposes all four family roles plus font size, line height, and letter spacing. A theme manifest may supply an arbitrary CSS stack for each role."
        }
      ],
      "children": []
    },
