    "b-srail-intro": {
      "id": "b-srail-intro",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The style rail is the right-docked authoring surface for tuning the active values defined by "
        },
        {
          "insert": "Themes",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/50-editor-design/40-visual-system/30-themes"
            }
          }
        },
        {
          "insert": " without leaving the workbench. Its mirrored layout keeps detail controls beside the document and navigation at the screen edge. This page defines the rail's geometry, navigation depth, override signals, reset scope, and control behavior."
        }
      ],
      "children": []
    },
