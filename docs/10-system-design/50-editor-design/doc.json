        {
          "insert": "Block vocabulary",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/40-block-vocabulary"
            }
          }
        },
        {
          "insert": ". The contract covers reading, editing, styling, shared visuals, and canvas and media behavior."
        }
