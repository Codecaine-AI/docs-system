    "b-20-rich-text-title-1": {
      "id": "b-20-rich-text-title-1",
      "type": "heading",
      "props": {
        "level": 1
      },
      "text": [
        {
          "insert": "Rich text: delta spans & reference chips"
        }
      ],
      "children": []
    },
    "b-20-rich-text-lead-2": {
      "id": "b-20-rich-text-lead-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Where a block carries text, that text is an array of Delta JSON spans: each span is a string "
        },
        {
          "insert": "insert",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " plus an optional "
        },
        {
          "insert": "attributes",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " object. There is no other inline model — no HTML, no nested marks tree. A span either has an attribute or it does not."
        }
      ],
      "children": []
    },
    "b-20-rich-text-delta-example-3": {
      "id": "b-20-rich-text-delta-example-3",
      "type": "code",
      "props": {
        "annotations": [
          {
            "lines": "3,5",
            "label": "Marks",
            "note": "Rich text is delta spans. Marks are literal true flags when present; absent marks are simply absent."
          },
          {
            "lines": "6",
            "label": "Outbound link",
            "note": "link is the external URL mark on the span that carries it."
          },
          {
            "lines": "11-15",
            "label": "Reference chip",
            "note": "reference carries the shared SpectreRef identity for doc mentions and canvas links alike: kind is doc or source, path is repo-relative, and label is display text."
          }
        ],
        "language": "json"
      },
      "text": [
        {
          "insert": "[\n  { \"insert\": \"Read \" },\n  { \"insert\": \"doc.json\", \"attributes\": { \"code\": true } },\n  { \"insert\": \" with \" },\n  { \"insert\": \"stable anchors\", \"attributes\": { \"bold\": true, \"italic\": true } },\n  { \"insert\": \" and a link\", \"attributes\": { \"link\": \"https://example.com/docs\" } },\n  { \"insert\": \" to \" },\n  {\n    \"insert\": \"the block vocabulary\",\n    \"attributes\": {\n      \"reference\": {\n        \"kind\": \"doc\",\n        \"path\": \"docs/10-system-design/10-block-vocabulary/00-overview.md\",\n        \"label\": \"the block vocabulary\"\n      }\n    }\n  },\n  { \"insert\": \".\" }\n]"
        }
      ],
      "children": []
    },
    "b-20-rich-text-marks-4": {
      "id": "b-20-rich-text-marks-4",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "The four marks"
        }
      ],
      "children": []
    },
    "b-20-rich-text-marks-rules-5": {
      "id": "b-20-rich-text-marks-rules-5",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The boolean marks are "
        },
        {
          "insert": "bold",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "italic",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "strike",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", and "
        },
        {
          "insert": "code",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Each must be the literal "
        },
        {
          "insert": "true",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " when present — "
        },
        {
          "insert": "false",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is a validation error, not a no-op. An attributes object that ends up empty after validation is dropped entirely, so there is exactly one canonical encoding of unmarked text."
        }
      ],
      "children": []
    },
    "b-20-rich-text-links-6": {
      "id": "b-20-rich-text-links-6",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Links and reference chips"
        }
      ],
      "children": []
    },
    "b-20-rich-text-link-mark-7": {
      "id": "b-20-rich-text-link-mark-7",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "link",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is a non-empty string URL for outbound destinations — external sites, mailto, anything the repo does not own. Internal identity is different: pointing at a doc or a source file uses the "
        },
        {
          "insert": "reference",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " attribute, which renders as a chip in the viewer and feeds the backlink index."
        }
      ],
      "children": []
    },
    "b-20-rich-text-spectre-ref-8": {
      "id": "b-20-rich-text-spectre-ref-8",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "SpectreRef — the shared reference identity"
        }
      ],
      "children": []
    },
    "b-20-rich-text-ref-example-9": {
      "id": "b-20-rich-text-ref-example-9",
      "type": "code",
      "props": {
        "annotations": [
          {
            "lines": "2",
            "label": "Two kinds",
            "note": "kind is \"doc\" for pages in the docs tree and \"source\" for code files."
          },
          {
            "lines": "3",
            "label": "Repo-relative",
            "note": "path is always repo-relative — no registry ids, no absolute paths in v1."
          },
          {
            "lines": "4-6",
            "label": "Optional precision",
            "note": "symbol, line, and section narrow the target; label is the display text the chip shows."
          }
        ],
        "language": "json"
      },
      "text": [
        {
          "insert": "{\n  \"kind\": \"source\",\n  \"path\": \"packages/docs-model/src/doc-schema.ts\",\n  \"symbol\": \"validateDocDocument\",\n  \"line\": 194,\n  \"label\": \"the validator\"\n}"
        }
      ],
      "children": []
    },
    "b-20-rich-text-ref-neutral-home-10": {
      "id": "b-20-rich-text-ref-neutral-home-10",
      "type": "callout",
      "props": {
        "kind": "One link model",
        "tone": "decision"
      },
      "text": [
        {
          "insert": "SpectreRef is the single reference identity shared by doc.json delta "
        },
        {
          "insert": "reference",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " spans and canvas "
        },
        {
          "insert": "links[].target",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". It lives in docs-model as the neutral home; the canvas project imports the type and aliases its on-disk link target to it. docs-model itself never imports from the canvas — the dependency points one way."
        }
      ],
      "children": []
    },
    "b-20-rich-text-carriers-11": {
