    "b-20-rich-text-bridges-out-15": {
      "id": "b-20-rich-text-bridges-out-15",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Outbound, "
        },
        {
          "insert": "delta-markdown.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " renders spans to inline markdown for the runtime projection. Reference marks project as plain text (label, falling back to the reference path) rather than link syntax — the projection is a greppable terminal artifact, and a bare bracket-and-paren pair would be noise for "
        },
        {
          "insert": "docs grep",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "."
        }
      ],
      "children": []
    },
    "b-20-rich-text-bridges-in-16": {
      "id": "b-20-rich-text-bridges-in-16",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Inbound, "
        },
        {
          "insert": "markdown-to-delta.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " tokenizes a line of inline markdown back into spans, covering exactly the inline vocabulary above. Link classification is deliberate: an href resolving under "
        },
        {
          "insert": "docs/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " becomes a "
        },
        {
          "insert": "kind: \"doc\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " reference, a source-code-looking path becomes "
        },
        {
          "insert": "kind: \"source\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", and everything else stays a plain "
        },
        {
          "insert": "link",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " mark."
        }
      ],
      "children": []
    },
