    "b-23-sequence-actions-note": {
      "id": "b-23-sequence-actions-note",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Three actions — "
        },
        {
          "insert": "sequence.setProgram",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "sequence.setStyle",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "sequence.setTitle",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — lifted at module load from "
        },
        {
          "insert": "SEQUENCE_AGENT_PATCH_OPERATIONS",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " in "
        },
        {
          "insert": "@codecaine-ai/sequence/agent-schema",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and carrying "
        },
        {
          "insert": "forward: { authority: \"sequence\" }",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " instead of a local "
        },
        {
          "insert": "apply",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "."
        }
      ],
      "children": []
