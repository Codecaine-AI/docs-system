          "insert": "sequence",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", the UML-style sequence-diagram block. The block is only a reference — "
        },
        {
          "insert": "src",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (or "
        },
        {
          "insert": "sequenceId",
          "attributes": {
            "code": true
