    "b-23-sequence-example-intro": {
      "id": "b-23-sequence-example-intro",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "A live block — the login flow from "
        },
        {
          "insert": "assets/sequences/login-flow.sequence.json",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — followed by the agent-facing program projection of the same document:"
        }
      ],
      "children": []
    },
    "b-23-sequence-embed-8": {
      "id": "b-23-sequence-embed-8",
