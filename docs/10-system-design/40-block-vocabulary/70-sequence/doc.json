    "b-23-sequence-lang-5": {
      "id": "b-23-sequence-lang-5",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Language essentials: numbers are participant identity, "
        },
        {
          "insert": "text=",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is a display name. Arrows are "
        },
        {
          "insert": ">",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " sync, "
        },
        {
          "insert": "->",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " async, "
        },
        {
          "insert": "-->",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " return. "
        },
        {
          "insert": "alt",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "opt",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "loop",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " fragments take "
        },
        {
          "insert": "guard=",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and nest by indentation alone — there is no "
        },
        {
          "insert": "end",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " keyword. "
        },
        {
          "insert": "note",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " attaches "
        },
        {
          "insert": "over",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "left",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "right",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " of a participant; activations are derived automatically. Styling lives in the document's separate style section, "
        },
        {
          "insert": "never",
          "attributes": {
            "italic": true
          }
        },
        {
          "insert": " in the program."
        }
      ],
      "children": []
    },
    "b-23-sequence-program-6": {
      "id": "b-23-sequence-program-6",
      "type": "code",
      "props": {},
      "text": [
        {
          "insert": "title \"Order distribution\"\nparticipant 1 text=order label=Order\nparticipant 2 text=careful label=\"Careful distributor\"\nparticipant 3 text=regular label=\"Regular distributor\"\nparticipant 4 text=messenger label=Messenger\n\nseq\n  loop guard=\"for each line item\"\n    alt guard=\"value > $15,000\"\n      1 > 2 text=dispatch\n    else\n      1 > 3 text=dispatch\n  opt guard=\"needs confirmation\"\n    1 -> 4 text=confirm"
        }
      ],
      "children": []
    },
