        {
          "insert": "external/sequence",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "external/sequence"
            }
          }
        },
        {
          "insert": "); participants, messages, and style never enter the doc. Sequence diagrams are this block's whole territory — every other diagram type belongs to the "
        },
        {
          "insert": "canvas",
          "attributes": {
            "reference": {
              "kind": "doc",
