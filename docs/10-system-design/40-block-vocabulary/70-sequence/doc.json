    "b-23-sequence-program-4": {
      "id": "b-23-sequence-program-4",
      "type": "code",
      "props": {},
      "text": [
        {
          "insert": "participant 1 text=user kind=actor\nparticipant 2 text=login label=\"Login page\"\nparticipant 3 text=db label=\"Database server\" stereotype=servlet\n\nseq\n  1 > 2 text=\"input(username, password)\"\n  2 > 3 text=\"fetch(username, password)\"\n  alt guard=fetching\n    3 --> 2 text=\"end fetching\"\n    2 > 1 text=success\n  else\n    2 --> 1 text=\"incorrect input\"\n  opt guard=\"needs confirmation\"\n    2 -> 3 text=confirm\n  note over=2 text=\"validates first\""
        }
      ],
      "children": []
    },
    "b-23-sequence-state-h": {
      "id": "b-23-sequence-state-h",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "State"
        }
      ],
      "children": []
    },
    "b-23-sequence-state-note": {
      "id": "b-23-sequence-state-note",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Three optional props — "
        },
        {
          "insert": "sequenceId",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "src",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "title",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — and no text ("
        },
        {
          "insert": "carriesText: false",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "); participants and messages live in the referenced "
        },
        {
          "insert": "SequenceDocument",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", never in block state."
        }
      ],
      "children": []
    },
    "b-23-sequence-actions-h": {
      "id": "b-23-sequence-actions-h",
