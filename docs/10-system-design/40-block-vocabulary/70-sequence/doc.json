      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "In the doc renderer the block fills through the host's "
        },
        {
          "insert": "renderSequence",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " slot (a placeholder card names the source otherwise); the markdown projection is a comment line — "
        },
        {
          "insert": "<!-- sequence: <src-or-sequenceId> [title=\"<title>\"] -->",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", or "
        },
        {
          "insert": "<!-- sequence: (missing src) -->",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " when no source is set."
        }
      ],
      "children": []
    },
