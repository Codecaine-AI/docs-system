    "b-seqfam-lead-3": {
      "id": "b-seqfam-lead-3",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The family is the vocabulary's flagship non-default agent-adapter case: its three typed actions carry "
        },
        {
          "insert": "forward: { authority: \"sequence\" }",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " instead of a local "
        },
        {
          "insert": "apply",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", so diagram edits route to the sequence engine and come back validated. The JSON document is the source of truth; a compact text program is the agent-facing projection — agents rewrite the whole program, and the language carries no styling, no coordinates, and no ids."
        }
      ],
      "children": []
    },
