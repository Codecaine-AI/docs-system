    "b-25-state-shape-actions-note-10": {
      "id": "b-25-state-shape-actions-note-10",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Four actions: three maintain the "
        },
        {
          "insert": "fields",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " tree, addressed by dot-path over sibling-unique field names — "
        },
        {
          "insert": "\"operations.params\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " names the "
        },
        {
          "insert": "params",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " field under "
        },
        {
          "insert": "operations",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "\"\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (or an omitted path) the root array. "
        },
        {
          "insert": "addField",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " rejects a duplicate sibling name; "
        },
        {
          "insert": "updateField",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " renames via "
        },
        {
          "insert": "patch.name",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", clears "
        },
        {
          "insert": "type",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "required",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "description",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " with "
        },
        {
          "insert": "null",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", and replaces the whole subtree via "
        },
        {
          "insert": "patch.fields",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " ("
        },
        {
          "insert": "null",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " removes it); "
        },
        {
          "insert": "removeField",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " takes the subtree with it. "
        },
        {
          "insert": "setExample",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " sets or clears the JSON example — "
        },
        {
          "insert": "example",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " must parse as JSON; "
        },
        {
          "insert": "null",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " clears it."
        }
      ],
      "children": []
