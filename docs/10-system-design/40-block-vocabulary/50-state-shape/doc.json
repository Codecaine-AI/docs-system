        },
        {
          "insert": " after the name, "
        },
        {
          "insert": "# <description>",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " at the end of the line. When an "
        },
        {
          "insert": "example",
          "attributes": {
            "code": true
