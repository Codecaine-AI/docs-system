        "annotations": [
          {
            "lines": "3-5",
            "label": "Guard",
            "note": "Rejects a document whose root pointer names no block — the tree invariant every reader assumes."
          },
          {
            "lines": "6",
            "note": "Callers get the resolved root shell, never the raw id."
          }
