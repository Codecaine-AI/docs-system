      "text": [
        {
          "insert": "export function requireRoot(doc: DocDocument): DocBlock {\n  const root = doc.blocks[doc.root];\n  if (!root) {\n    throw new Error(`missing root block: ${doc.root}`);\n  }\n  return root;\n}"
        }
