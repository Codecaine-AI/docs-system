    "b-stfam-state-intro": {
      "id": "b-stfam-state-intro",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "All state is four typed props — "
        },
        {
          "insert": "carriesText: false",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", no "
        },
        {
          "insert": "text",
