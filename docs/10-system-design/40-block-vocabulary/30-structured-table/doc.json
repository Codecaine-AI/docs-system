    "b-20-structured-table-lead-2": {
      "id": "b-20-structured-table-lead-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The structured-table family owns one block type, "
        },
        {
          "insert": "structured-table",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ": a columns × rows grid of rich-text cells kept in typed props, not prose — each cell is a plain string or a span array carrying inline marks. Use it for index tables, comparison matrices, and anything an agent should edit cell-by-cell instead of re-flowing text. Each section below instantiates one element of the block-design contract for this family."
        }
      ],
      "children": []
    },
