    "b-stfam-action-li-1": {
      "id": "b-stfam-action-li-1",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Column addressing takes exactly one of "
        },
        {
          "insert": "column",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (by name) or "
        },
        {
          "insert": "columnIndex",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (by position); name matching and the duplicate-name check compare the header's plain text."
