      "id": "b-20-structured-table-actions-10",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "structured-table.addRow",
            "description": "Insert a row (cells are inline markdown, padded/truncated to the column count); index defaults to the end.",
