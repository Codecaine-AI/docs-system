      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Five verbs cover the grid — the family's whole agent write surface for cells. Each action validates, applies against the block's current props, and returns a shallow props patch; rejections come back at "
        },
        {
          "insert": "$.params.<name>",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (an out-of-range index, a duplicate or unknown column name) without touching the document. The contract is "
        },
        {
          "insert": "Typed actions",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/30-data-model/20-block-design/20-typed-actions"
            }
          }
