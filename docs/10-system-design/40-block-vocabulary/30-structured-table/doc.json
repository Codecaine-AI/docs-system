          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-model/src/components/structured-table/state.ts"
            }
          }
        },
        {
          "insert": ". The contract is "
        },
        {
          "insert": "State schema",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/30-data-model/20-block-design/10-state-schema"
