      "type": "code",
      "props": {
        "annotations": [
          {
            "lines": "3,5",
            "label": "Marks",
            "note": "Rich text is delta spans. Marks are literal true flags when present; absent marks are simply absent."
          },
          {
            "lines": "6",
            "label": "Outbound link",
            "note": "link is the external URL mark on the span that carries it."
          },
          {
            "lines": "11-15",
            "label": "Reference chip",
            "note": "reference carries the shared SpectreRef identity for doc mentions and canvas links alike: kind is doc or source, path is corpus-relative, and label is display text."
          }
        ],
        "language": "json"
      },
      "text": [
        {
          "insert": "[\n  { \"insert\": \"Read \" },\n  { \"insert\": \"doc.json\", \"attributes\": { \"code\": true } },\n  { \"insert\": \" with \" },\n  { \"insert\": \"stable anchors\", \"attributes\": { \"bold\": true, \"italic\": true } },\n  { \"insert\": \" and a link\", \"attributes\": { \"link\": \"https://example.com/docs\" } },\n  { \"insert\": \" to \" },\n  {\n    \"insert\": \"the block vocabulary\",\n    \"attributes\": {\n      \"reference\": {\n        \"kind\": \"doc\",\n        \"path\": \"10-system-design/40-block-vocabulary\",\n        \"label\": \"the block vocabulary\"\n      }\n    }\n  },\n  { \"insert\": \".\" }\n]"
        }
      ],
