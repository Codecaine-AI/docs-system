      "id": "b-rtfam-state-lead-21",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The family's internal state is rich text itself: an array of Delta JSON spans in the block's text field — each span a string insert plus an optional attributes object. There is no other inline model — no HTML, no nested marks tree. A span either has an attribute or it does not."
        }
      ],
      "children": []
    },
    "b-20-rich-text-delta-example-3": {
