          "insert": "Example"
        }
      ],
      "children": []
    },
    "b-24-canvas-example-intro": {
      "id": "b-24-canvas-example-intro",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The block is only a reference into the external canvas system, and no canvas document ships with this corpus — so a props sample stands in for a live block:"
        }
      ],
      "children": []
    },
    "b-24-canvas-example-code": {
      "id": "b-24-canvas-example-code",
      "type": "code",
      "props": {
        "language": "json"
      },
      "text": [
        {
          "insert": "{\n  \"canvasId\": \"docs-architecture\",\n  \"view\": \"save-pipeline\",\n  \"title\": \"Save pipeline\"\n}"
        }
      ],
      "children": []
    },
