    "b-24-canvas-editor-12": {
      "id": "b-24-canvas-editor-12",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "In the editor — slash menu: "
        },
        {
          "insert": "Canvas",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " (aliases: diagram, drawing). The block stays a non-editable atom leaf in ProseMirror. Its inline surface is a static section preview, and doc edit mode may add an Edit in Canvas Studio action that opens the dedicated canvas editor rather than making the doc block itself mutable."
        }
      ],
      "children": []
    },
    "b-24-canvas-rendering-heading": {
      "id": "b-24-canvas-rendering-heading",
      "type": "heading",
      "props": {
        "level": 3
      },
      "text": [
        {
          "insert": "Host rendering contract"
        }
      ],
      "children": []
    },
    "b-24-canvas-rendering-inline": {
      "id": "b-24-canvas-rendering-inline",
      "type": "list-item",
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "Inline preview. The normal doc layout renders a deterministic SVG from the canvas preview endpoint. "
        },
        {
          "insert": "view",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " maps to the stable canvas section id, so the card shows that section as its main render. The inline surface does not capture drag, pan, or wheel zoom."
        }
      ],
      "children": []
    },
    "b-24-canvas-rendering-expanded": {
      "id": "b-24-canvas-rendering-expanded",
      "type": "list-item",
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "Expanded viewer. A top-right full-screen action opens a same-window overlay containing the dedicated read-only embed route. Pan, wheel zoom, Fit, and +/− belong here; canvas mutation does not. Escape or the close action restores the surrounding document at the same place."
        }
      ],
      "children": []
    },
    "b-24-canvas-rendering-edit": {
      "id": "b-24-canvas-rendering-edit",
      "type": "list-item",
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "Editor handoff. The Edit in Canvas Studio affordance appears only in an authoring context. It opens separately—a new browser tab, or the system browser from Electron—so changing the canvas does not discard the reader's document position or unsaved doc state."
        }
      ],
      "children": []
    },
    "b-24-canvas-rendering-portable": {
      "id": "b-24-canvas-rendering-portable",
      "type": "list-item",
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "Portable host seam. "
        },
        {
          "insert": "docs-viewer",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " supplies the canvas block slot; the host supplies its presentation. The workbench implementation pairs "
        },
        {
          "insert": "/api/canvases/:id/preview.svg?section=<view>",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " inline with "
        },
        {
          "insert": "/embed/:id?view=<view>",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " after expansion. Other React or webpage hosts can reproduce that same progression without importing the docs workbench."
        }
      ],
      "children": []
    },
    "b-24-canvas-proj-7": {
      "id": "b-24-canvas-proj-7",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The markdown projection is an HTML-comment reference line — "
        },
        {
          "insert": "<!-- canvas: <src-or-canvasId> [view=<view>] [title=\"<title>\"] -->",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", or "
        },
        {
          "insert": "<!-- canvas: (missing source) -->",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " when no source is set. Chosen over a markdown image because a canvas is not an image asset; the comment form greps cleanly on "
        },
        {
          "insert": "<!-- canvas:",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " without being misread as a broken image link."
        }
      ],
      "children": []
    },
