      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The operation list of the "
        },
        {
          "insert": "block vocabulary"
        },
        {
          "insert": ", and the operations surface of its documentation doctrine: where a "
        },
        {
          "insert": "state-shape",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/40-block-vocabulary/50-state-shape"
            }
          }
        },
        {
          "insert": " block carries a system's state — shape and example instance side by side — an interaction-surface lists the named operations by which that state is changed or queried; "
        },
        {
          "insert": "code",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/40-block-vocabulary/20-code-block"
            }
          }
        },
        {
          "insert": " blocks carry the source evidence."
        }
      ],
      "children": []
