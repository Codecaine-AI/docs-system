    "b-22-interaction-surface-lead-2": {
      "id": "b-22-interaction-surface-lead-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The interaction-surface component owns one block type, "
        },
        {
          "insert": "interaction-surface",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ": the operation list of the "
        },
        {
          "insert": "block vocabulary",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/40-block-vocabulary"
            }
          }
        },
        {
          "insert": ". A surface lists the named operations by which a state or system is changed, queried, or observed — operation signatures on a state, not HTTP endpoints. When documenting agentic systems it is one of the three types that carry the whole model: a "
        },
        {
          "insert": "state-shape",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/40-block-vocabulary/50-state-shape"
            }
          }
        },
        {
          "insert": " block holds the state — shape and example instance side by side — the interaction-surface lists the operations on it, and "
        },
        {
          "insert": "code",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/40-block-vocabulary/20-code-block"
            }
          }
        },
        {
          "insert": " blocks hold the source evidence. State first, then operations."
        }
      ],
      "children": []
    },
