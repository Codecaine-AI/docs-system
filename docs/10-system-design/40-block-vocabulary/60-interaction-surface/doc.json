    "b-22-interaction-surface-example-intro": {
      "id": "b-22-interaction-surface-example-intro",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "A live surface — two of the "
        },
        {
          "insert": "file-tree",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/40-block-vocabulary/40-file-tree"
            }
          }
        },
        {
          "insert": " block's entry operations. Each operation renders as its own card: signature left, description and param notes right; hovering a note lights the param's signature lines."
        }
      ],
      "children": []
    },
    "b-22-interaction-surface-example-block": {
      "id": "b-22-interaction-surface-example-block",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "file-tree.addEntry",
            "description": "Append a path entry (optional note and change marker) to the file tree.",
            "params": [
              {
                "name": "path",
                "type": "string",
                "required": true,
                "description": "/-separated path, no leading \"./\"; a trailing \"/\" marks an explicit directory."
              },
              {
                "name": "note",
                "type": "string",
                "required": false,
                "description": "Short annotation rendered after the path."
              },
              {
                "name": "change",
                "type": "\"added\" | \"removed\" | \"modified\" | \"renamed\"",
                "required": false,
                "description": "Change marker rendered as a badge."
              }
            ],
            "returns": "props patch: { entries }"
          },
          {
            "name": "file-tree.removeEntry",
            "description": "Remove the entry with the given path from the file tree.",
            "params": [
              {
                "name": "path",
                "type": "string",
                "required": true,
                "description": "Exact path of the entry to remove."
              }
            ],
            "returns": "props patch: { entries }"
          }
        ],
        "title": "file-tree — entry operations"
      },
      "children": []
    },
