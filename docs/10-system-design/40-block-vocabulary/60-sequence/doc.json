    "b-23-sequence-lead-2": {
      "id": "b-23-sequence-lead-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The sequence-diagram block of the "
        },
        {
          "insert": "block vocabulary"
        },
        {
          "insert": ": UML-style sequence diagrams rendered from a structured "
        },
        {
          "insert": "SequenceDocument",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". The JSON document is the source of truth; a compact text program is the agent-facing projection — agents rewrite the whole program, and the language carries no styling, no coordinates, and no ids. The engine lives in the standalone sequence repo ("
        },
        {
          "insert": "github.com/Codecaine-AI/sequence",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", a sibling checkout today, a future submodule at "
        },
        {
          "insert": "external/sequence",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "external/sequence"
            }
          }
        },
        {
          "insert": "); the docs-system block integration is upcoming."
        }
      ],
      "children": []
    },
    "b-23-sequence-callout-3": {
      "id": "b-23-sequence-callout-3",
      "type": "callout",
      "props": {
        "title": "Replaces mermaid",
        "tone": "info"
      },
      "text": [
        {
          "insert": "This block replaces the retired mermaid block. Sequence diagrams use this system; every other diagram type belongs to the "
        },
        {
          "insert": "canvas",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/40-block-vocabulary/70-canvas"
