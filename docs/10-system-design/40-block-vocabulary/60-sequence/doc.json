    "b-23-sequence-program-4": {
      "id": "b-23-sequence-program-4",
      "type": "code",
      "props": {},
      "text": [
        {
          "insert": "participant 1 text=user kind=actor\nparticipant 2 text=login label=\"Login page\"\nparticipant 3 text=db label=\"Database server\" stereotype=servlet\n\nseq\n  1 > 2 text=\"input(username, password)\"\n  2 > 3 text=\"fetch(username, password)\"\n  alt guard=fetching\n    3 --> 2 text=\"end fetching\"\n    2 > 1 text=success\n  else\n    2 --> 1 text=\"incorrect input\"\n  opt guard=\"needs confirmation\"\n    2 -> 3 text=confirm\n  note over=2 text=\"validates first\""
        }
      ],
      "children": []
    },
    "b-23-sequence-embed-8": {
      "id": "b-23-sequence-embed-8",
      "type": "sequence",
      "props": {
        "src": "assets/sequences/login-flow.sequence.json",
        "title": "Login flow"
      },
      "children": []
    },
    "b-23-sequence-lang-5": {
      "id": "b-23-sequence-lang-5",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Language essentials: numbers are participant identity, "
        },
        {
          "insert": "text=",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is a display name. Arrows are "
        },
        {
          "insert": ">",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " sync, "
        },
        {
          "insert": "->",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " async, "
        },
        {
          "insert": "-->",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " return. "
        },
        {
          "insert": "alt",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "opt",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "loop",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " fragments take "
        },
        {
          "insert": "guard=",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and nest by indentation alone — there is no "
        },
        {
          "insert": "end",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " keyword. "
        },
        {
          "insert": "note",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " attaches "
        },
        {
          "insert": "over",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "left",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "right",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " of a participant; activations are derived automatically. Styling lives in the document's separate style section, "
        },
        {
          "insert": "never",
          "attributes": {
            "italic": true
          }
        },
        {
          "insert": " in the program."
        }
