    "b-50-canonical-bytes-diff-callout-6": {
      "id": "b-50-canonical-bytes-diff-callout-6",
      "type": "callout",
      "props": {
        "kind": "Git-diff discipline",
        "tone": "decision"
      },
      "text": [
        {
          "insert": "Canonical bytes are a contract, not a convenience: every write path — server saves, migrations, authoring scripts — must round-trip through "
        },
        {
          "insert": "validateDocDocument",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and "
        },
        {
          "insert": "serializeDocDocument",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " before bytes reach disk. A hand-edited doc.json that validates but is not canonical will re-serialize to different bytes on its next save, polluting that diff."
        }
      ],
      "children": []
    },
    "b-50-canonical-bytes-defensive-7": {
      "id": "b-50-canonical-bytes-defensive-7",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "One defensive edge: if the serializer is handed an invalid document with unreachable blocks, it appends them after the document-order walk, sorted by id — even broken input serializes deterministically instead of depending on map iteration order."
        }
      ],
      "children": []
    },
    "b-ser-render-pointer-1": {
      "id": "b-ser-render-pointer-1",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The second derived form is the runtime markdown render: pure, never written to disk, so it can never go stale against the source of truth. Its per-type mappings belong to each block's "
        },
        {
          "insert": "agent renderer",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/30-data-model/20-block-design/40-agent-renderer"
            }
          }
        },
        {
          "insert": ", and the read contract to the "
        },
        {
          "insert": "agent surface",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/20-translation-layer/20-agent-surface"
            }
          }
        },
        {
          "insert": "."
        }
      ],
      "children": []
    },
