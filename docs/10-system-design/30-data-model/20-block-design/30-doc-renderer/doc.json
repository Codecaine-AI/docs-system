    "b-bdd-code-3": {
      "id": "b-bdd-code-3",
      "type": "code",
      "props": {
        "annotations": [
          {
            "lines": "4-7",
            "label": "Defensive by contract",
            "note": "The renderer re-checks its data; anything malformed renders the invalid-block placeholder — never a crash, never a guess."
          }
        ],
        "language": "typescript"
      },
      "text": [
        {
          "insert": "// trimmed from packages/docs-viewer/src/components/structured-table/descriptor.tsx\nfunction structuredTableData(block: DocBlock): StructuredTableData | null {\n  const { columns, rows } = block.props;\n  if (!Array.isArray(columns) || columns.length === 0) return null;\n  if (!columns.every((col): col is string => typeof col === \"string\")) return null;\n  if (!Array.isArray(rows)) return null;\n  // ...null means: render invalidBlockPlaceholder instead\n}"
        }
      ],
      "children": []
    },
