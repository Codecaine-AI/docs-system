      "id": "b-bdd-modes-s2",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Structural behavior (drag, select, delete) comes from the editor for free; the renderer supplies only what is specific to the type."
        }
      ],
      "children": []
    },
