      "id": "b-bds-intro-1",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Every block type declares a closed schema over its "
        },
        {
          "insert": "props",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — the type's whole state, and the only state it may hold. This page states what a schema owes and what a good one looks like."
        }
      ],
      "children": []
    },
    "b-bds-laidout-h-2": {
