    "b-bdg-code-3": {
      "id": "b-bdg-code-3",
      "type": "code",
      "props": {
        "annotations": [
          {
            "lines": "2",
            "label": "State in, string out",
            "note": "A pure function of the block — no I/O, no surface knowledge."
          },
          {
            "lines": "5",
            "label": "Degrade, never throw",
            "note": "Malformed props render best-effort text; the agent surface never crashes on a bad block."
          }
        ],
        "language": "typescript"
      },
      "text": [
        {
          "insert": "// trimmed from packages/docs-model/src/components/structured-table/agent-view.ts\nfunction projectStructuredTable(block: DocBlock): string {\n  const columns = readStringArray(block.props.columns);\n  const rows = readRows(block.props.rows);\n  // emits a GitHub markdown table: header, separator, one line per row\n}"
        }
      ],
      "children": []
    },
