    "b-bdaa-default-3": {
      "id": "b-bdaa-default-3",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Default: generic ops",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "b-bdaa-default-s1"
      ]
    },
    "b-bdaa-default-s1": {
      "id": "b-bdaa-default-s1",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Most types need nothing declared: the agent reads the doc render and edits through the generic ops and the type's actions."
        }
      ],
      "children": []
    },
    "b-bdaa-own-4": {
      "id": "b-bdaa-own-4",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Complex types bring their own agent",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "b-bdaa-own-s1",
        "b-bdaa-own-s2",
        "b-bdaa-own-s3"
      ]
    },
    "b-bdaa-own-s1": {
      "id": "b-bdaa-own-s1",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Canvas and sequence declare a processing agent of their own."
        }
      ],
      "children": []
    },
    "b-bdaa-own-s2": {
      "id": "b-bdaa-own-s2",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "A context loader assembles what that agent needs — the canvas file, the sequence source — instead of the doc render alone."
        }
      ],
      "children": []
    },
    "b-bdaa-own-s3": {
      "id": "b-bdaa-own-s3",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Writeback goes through the type's own actions, so validation and undo hold no matter who edits."
        }
      ],
      "children": []
    },
    "b-bdaa-disc-5": {
      "id": "b-bdaa-disc-5",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Discovery advertises the adapter",
          "attributes": {
            "bold": true
          }
        }
      ],
      "children": [
        "b-bdaa-disc-s1"
      ]
    },
    "b-bdaa-disc-s1": {
      "id": "b-bdaa-disc-s1",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "The annotation router learns from the registry which agent handles which type — routing is data, not hardcoded knowledge."
        }
      ],
      "children": []
    },
    "b-bdaa-direction-6": {
      "id": "b-bdaa-direction-6",
