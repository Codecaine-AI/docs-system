      "text": [
        {
          "insert": "resolveThemeById",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " loads a repository folder before the built-in definition with the same id. "
        },
        {
          "insert": "resolveThemeChain",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " flattens built-in bases, then "
        },
        {
          "insert": "compileThemeCss",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " emits light and dark variable blocks. Explicit selection injects that layer, normalizes "
        },
        {
          "insert": "railDefaults",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", applies the manifest mode, and stores the id under "
