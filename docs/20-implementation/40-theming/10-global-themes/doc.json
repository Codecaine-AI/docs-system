    "b-global-themes-saveas-rail-10-gloss": {
      "id": "b-global-themes-saveas-rail-10-gloss",
      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "An unlocked, non-static workbench writes after 1.5 seconds without another settings change. The manifest receives the complete normalized non-component settings as "
        },
        {
          "insert": "railDefaults",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "; registered component overrides are sent as sparse files."
        }
      ],
      "children": []
    },
    "b-global-themes-saveas-hand-11": {
      "id": "b-global-themes-saveas-hand-11",
      "type": "callout",
      "props": {
        "kind": "Implementation guard",
        "title": "Fresh profiles hydrate before writing",
        "tone": "info"
      },
      "text": [
        {
          "insert": "hasStoredStyleRailSettings",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " distinguishes a fresh profile from a stored one. A fresh profile loads and normalizes the repository Default's "
        },
        {
          "insert": "railDefaults",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " before "
        },
        {
          "insert": "settingsSeededRef",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " enables the autosave effect. Stock settings cannot overwrite the saved folder during boot."
        }
      ],
      "children": []
    },
    "b-global-themes-saveas-export-12": {
