      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "A global theme is loaded from "
        },
        {
          "insert": "themes/<id>/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", resolved against a built-in base, and compiled into a CSS layer. The workbench persists the active Default settings back to "
        },
        {
          "insert": "themes/default/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". What themes are allowed to change is specified by "
        },
        {
          "insert": "Themes",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/50-editor-design/40-visual-system/30-themes"
