      "type": "list-item",
      "props": {},
      "text": [
        {
          "insert": "Export serializes version, dark mode, and the complete settings object to "
        },
        {
          "insert": "docs-theme.json",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Import normalizes the settings payload before application and ignores invalid JSON without changing active state; it does not read or write a repository theme folder directly."
