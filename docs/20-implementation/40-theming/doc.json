        {
          "insert": "index.css",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and docs-viewer components reference tier-2 tokens only. docs-viewer's Tailwind classes may carry a neutral literal fallback inside "
        },
        {
          "insert": "var()",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (the package renders in hosts without this stylesheet); the workbench always defines the token, so fallbacks never win here."
