    "b-theming-overview-tiers-rule-10": {
      "id": "b-theming-overview-tiers-rule-10",
      "type": "callout",
      "props": {
        "title": "The one rule",
        "tone": "info"
      },
      "text": [
        {
          "insert": "Consumers never branch on light versus dark. A mode flip only swaps the tier 1 and tier 2 definitions; everything downstream re-resolves automatically."
        }
      ],
      "children": []
    },
