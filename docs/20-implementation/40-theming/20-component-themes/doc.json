    "b-component-themes-persistence-9": {
      "id": "b-component-themes-persistence-9",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "themes/default/theme.json",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " stores the complete normalized scalar settings under "
        },
        {
          "insert": "railDefaults",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", with an empty "
        },
        {
          "insert": "components",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " member. Each "
        },
        {
          "insert": "themes/default/components/*.json",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " file stores only the registered keys overridden for that surface. The server replaces the manifest and writes each component file supplied by the request; component files omitted from a request remain on disk."
        }
      ],
      "children": []
    },
