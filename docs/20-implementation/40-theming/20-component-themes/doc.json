      "props": {},
      "text": [
        {
          "insert": "A new theme knob requires the semantic variable in both mode blocks of "
        },
        {
          "insert": "semantic.css",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", a consumer that reads it through "
        },
        {
          "insert": "var(--docs-…)",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", and a typed entry in "
        },
        {
          "insert": "THEME_TOKEN_REGISTRY",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". The generic component pane reads registry metadata, so registered length and number entries receive sliders without a component-specific control. Per-block visual behavior remains in the "
        },
        {
          "insert": "Block vocabulary",
          "attributes": {
