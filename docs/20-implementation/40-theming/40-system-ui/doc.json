        "columns": [
          "Runtime",
          "Authority"
        ],
        "rows": [
          [
            "Unlocked workbench",
            "Local storage applies immediately. App.tsx also debounces the complete Default state into the repository theme folder."
          ],
          [
            "Fresh browser profile",
            "The repository Default railDefaults seed settings before theme-folder autosave is enabled."
          ],
          [
            "Theme-locked serve",
            "The repository Default applies unconditionally; rail local storage is ignored, the rail is hidden, and focus re-fetches inherited state."
          ],
          [
            "Static export",
            "No theme API exists and no repository writer starts. Bundled data and styles remain read-only."
          ]
        ]
      },
