    "b-system-ui-intro-2": {
      "id": "b-system-ui-intro-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Not everything is themable, on purpose. The system UI — the workbench's own furniture — stays fixed so every theme still FEELS like the same tool. This page draws that line explicitly, then maps every style-rail knob to what it actually writes."
        }
      ],
      "children": []
    },
