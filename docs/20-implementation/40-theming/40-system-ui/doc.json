        }
      ],
      "children": []
    },
    "b-system-ui-knobs-para-7": {
      "id": "b-system-ui-knobs-para-7",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "packages/docs-workbench/web/src/shell/StyleRail.tsx",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-workbench/web/src/shell/StyleRail.tsx"
            }
          }
        },
        {
          "insert": " owns the settings type, compiled defaults, tolerant local-storage reader, normalization, variable conversion, and root application."
        }
      ],
      "children": []
    },
    "b-system-ui-fixed-table-4": {
      "id": "b-system-ui-fixed-table-4",
      "type": "structured-table",
      "props": {
        "columns": [
          "Stage",
          "Mechanic"
        ],
        "rows": [
          [
            "Load",
            "loadStyleRailSettings parses docs-style-rail-settings.v1. Missing or invalid JSON returns the compiled defaults."
          ],
          [
            "Normalize",
            "normalizeSettings fills every settings group, accepts both stored locations for surfaces/contentWidth, clamps scalar ranges, and filters component overrides through the registry."
          ],
          [
            "Translate",
            "styleRailVars returns one map of CSS-variable names to serialized strings or null. Registered component values pass through the same map."
          ],
          [
            "Apply",
            "applyStyleRailVars sets non-null values on document.documentElement.style and removes properties whose value is null."
          ],
          [
            "Persist locally",
            "saveStyleRailSettings writes the normalized object for unlocked serves; storage failure leaves the in-memory settings active."
          ]
        ]
      },
      "children": []
    },
    "b-system-ui-fixed-note-5": {
      "id": "b-system-ui-fixed-note-5",
      "type": "callout",
      "props": {
        "kind": "Implementation invariant",
        "title": "Default means no inline property",
        "tone": "info"
      },
      "text": [
        {
          "insert": "A scalar equal to "
        },
        {
          "insert": "DEFAULT_STYLE_RAIL_SETTINGS",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " normally translates to "
        },
        {
          "insert": "null",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Removing the property exposes the active theme or semantic stylesheet instead of copying a competing default into inline style."
        }
      ],
      "children": []
    },
