      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The style-rail runtime normalizes persisted settings, translates them to CSS custom properties, and applies them to the document root. It also separates local session state from repository Default persistence and locked-theme inheritance. The control layout is specified by "
        },
        {
          "insert": "Style Rail",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/50-editor-design/30-style-rail"
            }
          }
        },
        {
          "insert": "; the customization boundary is specified by "
        },
        {
          "insert": "Visual System",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/50-editor-design/40-visual-system"
            }
          }
        },
        {
          "insert": "."
        }
      ],
      "children": []
    },
