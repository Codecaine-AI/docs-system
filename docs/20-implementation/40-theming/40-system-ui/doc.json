    "b-system-ui-knobs-para-7": {
      "id": "b-system-ui-knobs-para-7",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The rail has two tabs — Theme (identity: themes, colors, typography, components, background effect) and Layout (geometry: column, surfaces, editor controls) — each a stack of collapsible sections whose open state persists per user. Every knob writes CSS variables onto the root element (a knob at its default removes the override). The full inventory:"
        }
      ],
      "children": []
    },
