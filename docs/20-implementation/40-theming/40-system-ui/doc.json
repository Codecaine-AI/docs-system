      "text": [
        {
          "insert": "Promoting any of these to themable is a deliberate decision: add a tier-2 token + registry entry (see Component themes), never a one-off knob. The default answer is no — a consistent workbench frame is a feature."
        }
      ],
      "children": []
    },
