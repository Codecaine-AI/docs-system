    "b-00-using-the-workbench-while-your-editor-is-cle-12": {
      "id": "b-00-using-the-workbench-while-your-editor-is-cle-12",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "  while your editor is clean, the change applies silently and the affected\n  blocks flash. While you have unsaved edits, remote refreshes are\n  suppressed — conflicts are handled at save time instead (below)."
        }
      ],
      "children": []
    },
    "b-00-using-the-workbench-links-cmd-ctrl-k-with-29": {
      "id": "b-00-using-the-workbench-links-cmd-ctrl-k-with-29",
      "type": "list-item",
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "Links.",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " "
        },
        {
          "insert": "Cmd/Ctrl+K",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " with text selected opens a Notion-style link popover\n  (Enter applies, an empty input or the Remove button clears). Pasting a URL\n  over selected text wraps the selection in a link instead of replacing it."
        }
      ],
      "children": []
    },
    "b-00-using-the-workbench-video-paste-a-youtube-30": {
