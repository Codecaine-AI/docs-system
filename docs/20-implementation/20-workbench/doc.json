    "b-00-using-the-workbench-the-page-is-the-editor-4": {
      "id": "b-00-using-the-workbench-the-page-is-the-editor-4",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The page "
        },
        {
          "insert": "is",
          "attributes": {
            "italic": true
          }
        },
        {
          "insert": " the editor — Notion-style. There is no read mode and no Save\nbutton:"
        }
      ],
      "children": []
    },
    "b-00-using-the-workbench-auto-save-edits-sav-5": {
      "id": "b-00-using-the-workbench-auto-save-edits-sav-5",
      "type": "list-item",
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "Auto-save.",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " Edits save on a ~1s idle debounce (with a 5s max-wait so"
        }
      ],
      "children": []
    },
    "b-00-using-the-workbench-continuous-typing-still-6": {
      "id": "b-00-using-the-workbench-continuous-typing-still-6",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "  continuous typing still persists). "
        },
        {
          "insert": "Cmd/Ctrl+S",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " forces an immediate\n  flush. Drafts also flush when the window blurs, the tab hides, you switch\n  modes, or you navigate to another doc."
        }
      ],
      "children": []
    },
