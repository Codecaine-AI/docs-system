          "insert": "Video.",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " Paste or drop a YouTube/Vimeo/Loom URL on an empty line to embed\n  it as a video block (there is deliberately no slash-menu entry — video\n  blocks come from content). Dropping a video file from disk ("
        },
        {
          "insert": "mp4",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "webm",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "mov",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "m4v",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", up to 64 MB) uploads it into the bundle's "
        },
        {
          "insert": "assets/videos/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and inserts\n  the block once the upload lands."
        }
