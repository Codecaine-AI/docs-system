    "b-00-using-the-workbench-live-changes-if-ano-11": {
      "id": "b-00-using-the-workbench-live-changes-if-ano-11",
      "type": "list-item",
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "Live changes.",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " If another actor (a teammate, an agent) edits the doc"
        }
      ],
      "children": []
