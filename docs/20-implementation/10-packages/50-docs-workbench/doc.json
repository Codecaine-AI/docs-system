    "b-50-docs-workbench-composition-decision-10": {
      "id": "b-50-docs-workbench-composition-decision-10",
      "type": "callout",
      "props": {
        "kind": "Decision",
        "title": "The Write and Render Sides Meet Here",
        "tone": "decision"
      },
      "text": [
        {
          "insert": "docs-workbench is a deliberately thin composition point. Keeping the runnable app non-load-bearing lets another host embed docs-server or docs-viewer without inheriting this shell, and lets this shell change without changing the contracts below it."
        }
      ],
      "children": []
    },
    "b-50-docs-workbench-cut-detail-19": {
      "id": "b-50-docs-workbench-cut-detail-19",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "This boundary is forced at the deliverable level, not at the library level. A runnable installation needs server startup, browser routing, transport policy, session identity, host-provided embeds, settings persistence, and optional desktop lifecycle. None of those concerns changes the document format, write authority, or viewer contract, so they remain replaceable host glue."
        }
      ],
      "children": []
    },
    "b-50-docs-workbench-boundary-review-15": {
      "id": "b-50-docs-workbench-boundary-review-15",
      "type": "callout",
      "props": {
        "kind": "Open call",
        "title": "The CLI and App May Converge",
        "tone": "info"
      },
      "text": [
        {
          "insert": "Merging docs-cli and docs-workbench remains a live candidate. "
        },
        {
          "insert": "docs-cli — the agent dialect",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "20-implementation/10-packages/60-docs-cli"
            }
          }
        },
        {
          "insert": " already delegates "
        },
        {
          "insert": "serve",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and "
        },
        {
          "insert": "export",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " to this package. The current command-surface versus app-shell split is a judgment call, not an incompatible-runtime boundary."
        }
      ],
      "children": []
    },
