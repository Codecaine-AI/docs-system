    "b-50-docs-workbench-composition-decision-10": {
      "id": "b-50-docs-workbench-composition-decision-10",
      "type": "callout",
      "props": {
        "kind": "Package decision",
        "title": "The write and render sides meet here",
        "tone": "decision"
      },
      "text": [
        {
          "insert": "This package is the composition point: it is the only place where the docs-server write side and the docs-viewer render side are allowed to meet. Keeping that composition in a thin package makes it non-load-bearing: hosts that embed either piece individually do not pay for the app shell, and the shell can be rebuilt without changing any layer beneath it. The boundary exists because this is a deliverable app, not a library."
        }
      ],
      "children": []
    },
