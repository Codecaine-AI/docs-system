    "b-50-docs-workbench-lead-2": {
      "id": "b-50-docs-workbench-lead-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "@codecaine-ai/docs-workbench",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is the runnable Bun server, Vite SPA, and Electron wrapper for a docs tree. It is the only package where "
        },
        {
          "insert": "docs-server — the Mutation Authority",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "20-implementation/10-packages/30-docs-server"
            }
          }
        },
        {
          "insert": " and "
        },
        {
          "insert": "docs-viewer — rendering and editing",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "20-implementation/10-packages/40-docs-viewer"
            }
          }
        },
        {
          "insert": " meet. The package owns the host policy that connects them, not either side's reusable logic."
        }
      ],
      "children": []
    },
    "b-50-docs-workbench-why-heading-9": {
      "id": "b-50-docs-workbench-why-heading-9",
