      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "@codecaine-ai/docs-workbench is the standalone runnable docs app and its thin composition shell. It joins the write side to the render side in an Elysia-served Vite SPA without moving either side's responsibilities into the app."
        }
      ],
      "children": []
    },
    "b-50-docs-workbench-owns-heading-3": {
      "id": "b-50-docs-workbench-owns-heading-3",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "What it owns"
        }
      ],
      "children": []
    },
    "b-50-docs-workbench-owns-scope-4": {
      "id": "b-50-docs-workbench-owns-scope-4",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The runnable is deliberately small: roughly a dozen source files under "
        },
        {
          "insert": "packages/docs-workbench/src/",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-workbench/src"
            }
          }
        },
        {
          "insert": " plus the Vite SPA under "
        },
        {
          "insert": "packages/docs-workbench/web/",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-workbench/web"
            }
          }
        },
        {
          "insert": ". The package owns composition and app behavior, not the server's route semantics or the viewer's rendering primitives."
        }
      ],
      "children": []
    },
