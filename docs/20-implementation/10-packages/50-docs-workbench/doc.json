              "path": "packages/docs-workbench/src/export.ts"
            }
          }
        },
        {
          "insert": " packages the same SPA with a different data adapter. It writes the docs tree, bundle-shaped snapshots, rendered Markdown, backlinks, and files under asset directories beside the static build. It reuses docs-model, docs-index, and docs-server read helpers rather than recreating their semantics in an exporter."
