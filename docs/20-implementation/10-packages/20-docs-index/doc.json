    "b-20-docs-index-lead-2": {
      "id": "b-20-docs-index-lead-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "@codecaine-ai/docs-index",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is the Bun-side package that derives inbound-reference lookup from canonical document bundles and canvas sidecars. It owns SQLite storage, reference-path identity, docs-root confinement, and move-time inbound fixup. "
        },
        {
          "insert": "Doc standards",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/10-doc-standards"
            }
          }
        },
        {
          "insert": " defines the corpus-level linking contract; this package makes that contract queryable and maintainable."
        }
      ],
      "children": []
    },
