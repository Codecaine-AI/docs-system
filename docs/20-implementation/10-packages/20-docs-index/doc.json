            "returns": "Promise<Database>"
          },
          {
            "name": "upsertForSource",
            "description": "Transactionally replace every row for one document or canvas source.",
            "params": [
              {
                "name": "db",
                "type": "Database",
                "required": true
              },
              {
                "name": "sourcePath",
                "type": "string",
                "required": true
              },
              {
                "name": "refs",
                "type": "BacklinkRef[]",
                "required": true
