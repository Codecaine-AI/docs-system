    "b-20-docs-index-runtime-boundary-7": {
      "id": "b-20-docs-index-runtime-boundary-7",
      "type": "callout",
      "props": {
        "kind": "Decision",
        "title": "Bun forces the runtime boundary",
        "tone": "decision"
      },
      "text": [
        {
          "insert": "bun:sqlite",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " cannot enter a browser bundle. The index must therefore stay outside "
        },
        {
          "insert": "@codecaine-ai/docs-model",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and "
        },
        {
          "insert": "@codecaine-ai/docs-viewer",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". This constraint forces server-side placement; it does not by itself force a package separate from docs-server."
        }
      ],
      "children": []
    },
    "b-20-docs-index-boundary-review-14": {
      "id": "b-20-docs-index-boundary-review-14",
      "type": "callout",
      "props": {
        "kind": "Open call",
        "title": "docs-index may merge into docs-server",
        "tone": "info"
      },
      "text": [
        {
          "insert": "The merge remains unresolved. "
        },
        {
          "insert": "docs-server — the Mutation Authority",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "20-implementation/10-packages/30-docs-server"
            }
          }
        },
        {
          "insert": " is the primary consumer and already owns the save hooks and connection cache, so co-location would remove glue. The present split keeps a derived, HTTP-free service usable by link checks and maintenance scripts without constructing a server. Neither advantage is a forcing constraint."
        }
      ],
      "children": []
    },
