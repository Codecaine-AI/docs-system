          {
            "name": "queryInbound / queryInboundTolerant",
            "description": "Read exact stored targets or union every accepted document-path alias.",
            "params": [
              {
                "name": "db",
                "type": "Database",
                "required": true
              },
              {
                "name": "targetPath",
                "type": "string",
                "required": true
              }
            ],
            "returns": "BacklinkRow[]"
          },
          {
            "name": "rescanAll",
            "description": "Rebuild the complete table from doc.json bundles and canvas sidecars under a docs root.",
            "params": [
              {
                "name": "docsRoot",
                "type": "string",
                "required": true
              },
              {
                "name": "db",
                "type": "Database",
                "required": false
              }
            ],
            "returns": "{ dbPath, sourcesScanned, refsIndexed }"
          },
          {
            "name": "normalizeDocRefPath",
