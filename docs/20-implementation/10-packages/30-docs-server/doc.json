          "insert": "guide",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", and "
        },
        {
          "insert": "guide/doc.json",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " address the same lock. A foreign live session receives "
        },
        {
          "insert": "423",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "; the holder passes. Expiry, absence, or loss of a lock never proves freshness, so the hash precondition remains the correctness backstop."
        }
      ],
      "children": []
    },
    "b-30-docs-server-validation-heading-34": {
      "id": "b-30-docs-server-validation-heading-34",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Validation Guards the Reload Boundary"
        }
      ],
      "children": []
    },
    "b-30-docs-server-validation-gate-35": {
      "id": "b-30-docs-server-validation-gate-35",
      "type": "callout",
      "props": {
        "kind": "Write gate",
        "title": "Invalid post-op documents never reach disk",
        "tone": "warning"
      },
      "text": [
        {
          "insert": "Operation application cannot establish that every rich-text span and cross-reference is reloadable. The server therefore validates the complete post-op document before persistence. Failure returns "
        },
        {
          "insert": "422",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " with issue paths; the existing file, undo ledger, and backlinks index remain untouched."
        }
      ],
      "children": []
    },
    "b-30-docs-server-validation-detail-36": {
      "id": "b-30-docs-server-validation-detail-36",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "A successful gate persists the validator's normalized document rather than the unchecked operation result. That makes the returned hash match the next load's canonical bytes. "
        },
        {
          "insert": "packages/docs-server/src/__tests__/doc-validation-gate.routes.test.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-server/src/__tests__/doc-validation-gate.routes.test.ts"
            }
          }
        },
        {
          "insert": " locks the refusal shape and byte-unchanged guarantee."
        }
      ],
      "children": []
    },
    "b-30-docs-server-undo-heading-37": {
      "id": "b-30-docs-server-undo-heading-37",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Undo Reuses the Authority"
        }
      ],
      "children": []
    },
    "b-30-docs-server-undo-9": {
      "id": "b-30-docs-server-undo-9",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "packages/docs-server/src/patch-ledger.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-server/src/patch-ledger.ts"
            }
          }
        },
        {
          "insert": " stores each document patch's path, inverse operations, and "
        },
        {
          "insert": "hashAfterApply",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " under a "
        },
        {
          "insert": "patch_id",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". The ledger is process-local and is an undo stack, not durable history."
        }
      ],
      "children": []
    },
    "b-30-docs-server-undo-detail-38": {
      "id": "b-30-docs-server-undo-detail-38",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "undo_patch",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " in "
        },
        {
          "insert": "packages/docs-server/src/agent-tools.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-server/src/agent-tools.ts"
            }
          }
        },
        {
          "insert": " sends a document inverse back through "
        },
        {
          "insert": "applyDocOpsToBundle",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " with "
        },
        {
          "insert": "hashAfterApply",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " as the precondition. Later edits produce "
        },
        {
          "insert": "409",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and survive untouched. Success consumes the original token, so a second use returns "
        },
        {
          "insert": "404",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Canvas and sequence patches store validated prior snapshots and restore them under a path lock, hash precondition, and atomic write."
        }
      ],
      "children": []
    },
    "b-30-docs-server-events-heading-39": {
      "id": "b-30-docs-server-events-heading-39",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Events Follow Commits"
        }
      ],
      "children": []
    },
    "b-30-docs-server-events-10": {
      "id": "b-30-docs-server-events-10",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "packages/docs-server/src/docs-events.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-server/src/docs-events.ts"
            }
          }
        },
        {
          "insert": " carries change hints shaped as "
        },
        {
          "insert": "{ path, changedIds, patchId, actor }",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Route handlers publish only after their mutation succeeds. The payload identifies what may have changed and who caused it; canonical state remains on disk and clients re-fetch it."
        }
      ],
      "children": []
    },
    "b-30-docs-server-events-detail-40": {
      "id": "b-30-docs-server-events-detail-40",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "GET /api/events",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " adapts the root-scoped in-process pub/sub to SSE. Each connection owns a queue, receives an immediate named frame so headers flush, receives unnamed JSON change messages, emits keepalives while idle, and unsubscribes on close. The stream is neither persisted nor fanned out across processes."
        }
      ],
      "children": []
    },
    "b-30-docs-server-fs-events-41": {
      "id": "b-30-docs-server-fs-events-41",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "packages/docs-server/src/fs-watch.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-server/src/fs-watch.ts"
            }
          }
        },
        {
          "insert": " lets a host feed hand edits and other out-of-band writes into the same stream. It marks them with actor "
        },
        {
          "insert": "fs",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", ignores backlinks database paths and atomic temporary names, and debounces repeated paths."
        }
      ],
      "children": []
    },
    "b-30-docs-server-forward-heading-42": {
      "id": "b-30-docs-server-forward-heading-42",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Forwarded Actions Keep Authority Honest"
        }
      ],
      "children": []
    },
    "b-30-docs-server-ops-13": {
      "id": "b-30-docs-server-ops-13",
      "type": "callout",
      "props": {
        "kind": "Authority boundary",
        "title": "A forwarded action travels alone",
        "tone": "decision"
      },
      "text": [
        {
          "insert": "POST /api/ops",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " refuses a batch that mixes a forwarded canvas or sequence action with any other operation. The server cannot promise one atomic transaction across the document file and another authority's sidecar, so it does not present the batch as atomic."
        }
      ],
      "children": []
    },
    "b-30-docs-server-forward-detail-43": {
      "id": "b-30-docs-server-forward-detail-43",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The docs-model action registry identifies the forwarding authority. "
        },
        {
          "insert": "packages/docs-server/src/store.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-server/src/store.ts"
            }
          }
        },
        {
          "insert": " coordinates the document precondition and the canvas or sequence patch under the document path lock. The document bytes stay unchanged. The route returns the updated sidecar, its hash, and an undo token, then publishes the changed IDs in the sidecar event."
        }
      ],
      "children": []
    },
    "b-30-docs-server-dependencies-heading-19": {
      "id": "b-30-docs-server-dependencies-heading-19",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Invariants and Firewalls"
        }
      ],
      "children": []
    },
    "b-30-docs-server-dependency-table-44": {
      "id": "b-30-docs-server-dependency-table-44",
      "type": "structured-table",
      "props": {
        "columns": [
          "Invariant",
          "Mechanism",
          "Consequence"
        ],
        "density": "compact",
        "rows": [
          [
            "UI-free",
            "The manifest and source imports contain no React, docs-viewer, or docs-workbench dependency.",
            "A host can mount the server without bundling a browser UI."
          ],
          [
            "Host-neutral",
            "DocsStore accepts one docs root and root-relative paths.",
            "Project records, authentication, and host databases stay outside the package."
          ],
          [
            "Reloadable documents",
            "Every accepted doc-op result passes complete document validation before atomic persistence.",
            "An editor or agent bug cannot persist a doc.json that the next load refuses."
          ],
          [
            "Single-process coordination",
            "Path mutexes, draft locks, the undo ledger, and event listeners live in memory.",
            "Horizontal or multi-process deployment requires a different coordination layer."
          ],
          [
            "Derived backlinks",
            "Reindexing begins after commit and swallows index failures.",
            "A broken or locked index cannot fail a document save."
          ]
        ],
        "title": "Server boundary"
      },
      "children": []
    },
    "b-30-docs-server-depends-on-20": {
      "id": "b-30-docs-server-depends-on-20",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The dependency manifest in "
        },
        {
          "insert": "packages/docs-server/package.json",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-server/package.json"
            }
          }
        },
        {
          "insert": " allows server-side dependencies: docs-model for format and operations, docs-index for paths and backlinks, canvas and sequence for sidecar authorities, and Elysia for HTTP. React and docs-viewer remain outside the graph."
        }
      ],
      "children": []
    },
    "b-30-docs-server-depended-on-21": {
      "id": "b-30-docs-server-depended-on-21",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Path acceptance is also part of the authority boundary. "
        },
        {
          "insert": "packages/docs-server/src/confine.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-server/src/confine.ts"
            }
          }
        },
        {
          "insert": " rejects traversal and invalid asset or sidecar shapes; write-safe sidecar resolvers canonicalize the deepest existing ancestor so a symlink cannot redirect a mutation outside the docs root."
        }
      ],
      "children": []
    },
    "b-30-docs-server-process-invariant-45": {
      "id": "b-30-docs-server-process-invariant-45",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The mutation authority assumes one Bun process owns a docs root. "
        },
        {
          "insert": "withPathLock",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " prevents races among callers in that process; it is not a cross-process file lock."
        }
      ],
      "children": []
    },
    "b-30-docs-server-derived-invariant-46": {
      "id": "b-30-docs-server-derived-invariant-46",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Backlinks remain derived state. "
        },
        {
          "insert": "packages/docs-server/src/backlinks-cache.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-server/src/backlinks-cache.ts"
            }
          }
        },
        {
          "insert": " caches a database connection by resolved docs root and makes save-path indexing best-effort. Persistence succeeds or fails before the index is consulted."
        }
      ],
      "children": []
    },
