    "b-30-docs-server-title-1": {
      "id": "b-30-docs-server-title-1",
      "type": "heading",
      "props": {
        "level": 1
      },
      "text": [
        {
          "insert": "One Server Owns Every Accepted Write"
        }
      ],
      "children": []
    },
    "b-30-docs-server-lead-2": {
      "id": "b-30-docs-server-lead-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "@codecaine-ai/docs-server",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is the React-free mutation authority for one filesystem-backed docs tree. It binds reads, preconditioned writes, undo, and change notifications to an explicit docs root, combines them with process-local draft locks, then exposes the same authority through TypeScript and an embeddable Elysia route factory. This page describes the server's internal guarantees; "
        },
        {
          "insert": "The save pipeline: keystroke to disk",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "20-implementation/30-save-pipeline"
            }
          }
        },
        {
          "insert": " owns the cross-package path from editor input to persistence."
        }
      ],
      "children": []
    },
