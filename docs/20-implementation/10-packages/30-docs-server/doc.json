    "b-30-docs-server-surface-26": {
      "id": "b-30-docs-server-surface-26",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "createDocsStore",
            "description": "Bind the server's read, mutation, undo, backlinks, lock, and event methods to one resolved docs root.",
            "params": [
              {
                "name": "docsRoot",
                "type": "string",
                "required": true
              }
            ],
            "returns": "DocsStore"
          },
          {
            "name": "createDocsRoutes",
            "description": "Adapt a DocsStore to an embeddable Elysia plugin mounted under /api/*.",
            "params": [
              {
                "name": "store",
                "type": "DocsStore",
                "required": true
              },
              {
                "name": "options",
                "type": "{ themeLocked?: boolean }",
                "required": false
              }
            ],
            "returns": "Elysia plugin"
          },
          {
            "name": "POST /api/ops",
            "description": "Apply document operations or route one forwarded canvas or sequence action through its owning authority.",
            "params": [
              {
                "name": "path",
                "type": "string",
                "required": true
              },
              {
                "name": "ops",
                "type": "DocOp[]",
                "required": true
              },
              {
                "name": "expected_hash",
                "type": "string",
                "required": false
              },
              {
                "name": "expected_canvas_hash",
                "type": "string",
                "required": false
              },
              {
                "name": "expected_sequence_hash",
                "type": "string",
                "required": false
              },
              {
                "name": "session_id",
                "type": "string",
                "required": false
              }
            ],
            "returns": "canonical document or sidecar, authority hash, and patch_id; refusal status depends on the selected authority"
          },
          {
            "name": "POST /api/undo",
            "description": "Consume one undo token only if the target still matches the hash recorded after the original apply.",
            "params": [
              {
                "name": "patch_id",
                "type": "string",
                "required": true
              }
            ],
            "returns": "restored document or sidecar and new hash; 404 or 409 on refusal"
          },
          {
            "name": "POST /api/draft-lock/{acquire,heartbeat,release}",
            "description": "Coordinate an expiring editor claim without replacing content-hash correctness.",
            "params": [
              {
                "name": "kind",
                "type": "\"doc\" | \"canvas\" | \"sequence\"",
                "required": true
              },
              {
                "name": "path",
                "type": "string",
                "required": true
              },
              {
                "name": "sessionId",
                "type": "string",
                "required": true
              }
            ],
            "returns": "lock state or 423 when another session holds it"
          },
          {
            "name": "GET /api/events",
            "description": "Stream committed and out-of-band change hints to clients over SSE.",
            "returns": "connected and keepalive frames plus DocsChangeEvent messages"
          }
        ],
        "title": "docs-server — authority seams"
      },
      "children": []
