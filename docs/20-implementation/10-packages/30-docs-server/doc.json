      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The normal mutation protocol supplies "
        },
        {
          "insert": "expected_hash",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". The server compares it with the canonical hash derived after load-time validation and serialization. A mismatch returns "
