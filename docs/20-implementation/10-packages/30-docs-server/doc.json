      "id": "b-30-docs-server-depends-on-20",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "docs-server depends on "
        },
        {
          "insert": "docs-model",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "20-implementation/10-packages/10-docs-model"
            }
          }
        },
        {
          "insert": " for schema and inverse-producing mutation application; "
        },
        {
          "insert": "docs-index",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "20-implementation/10-packages/20-docs-index"
            }
          }
        },
        {
          "insert": " for backlinks upkeep; "
        },
        {
          "insert": "@codecaine-ai/canvas",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " for the canvas authority; and "
        },
        {
          "insert": "elysia",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " for the HTTP route layer. It has no React dependency."
        }
      ],
      "children": []
    },
    "b-30-docs-server-depended-on-21": {
      "id": "b-30-docs-server-depended-on-21",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "In the other direction, "
        },
        {
          "insert": "docs-workbench",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "20-implementation/10-packages/50-docs-workbench"
            }
          }
        },
        {
          "insert": " depends on docs-server and wraps these routes."
        }
      ],
      "children": []
    },
    "b-30-docs-server-alone-heading-22": {
      "id": "b-30-docs-server-alone-heading-22",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Using it alone"
        }
      ],
      "children": []
    },
    "b-30-docs-server-alone-23": {
      "id": "b-30-docs-server-alone-23",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Use docs-server alone when a host application supplies its own front end. Create "
        },
        {
          "insert": "createDocsStore(docsRoot)",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", mount "
        },
        {
          "insert": "createDocsRoutes(store)",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " in the host's Elysia server, and connect that host-owned UI to the embedded mutation API."
        }
      ],
      "children": []
    }
