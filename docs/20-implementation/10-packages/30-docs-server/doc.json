    "b-30-docs-server-root-scope-28": {
      "id": "b-30-docs-server-root-scope-28",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "createDocsStore(docsRoot)",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " in "
        },
        {
          "insert": "packages/docs-server/src/store.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-server/src/store.ts"
            }
          }
        },
        {
          "insert": " resolves the supplied root once and closes every method over it. The resolved root is also the change-event channel, so store instances bound to the same tree share notifications. Draft locks are process-wide and keyed by kind plus root-relative path, so different roots in one process share that lock namespace. The factory does not cache stores; the host keeps and shares one store instance for each root it serves."
        }
      ],
      "children": []
    },
    "b-30-docs-server-root-scope-decision-29": {
      "id": "b-30-docs-server-root-scope-decision-29",
      "type": "callout",
      "props": {
