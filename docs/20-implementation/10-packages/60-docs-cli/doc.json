    "b-60-docs-cli-command-table-4": {
      "id": "b-60-docs-cli-command-table-4",
      "type": "structured-table",
      "props": {
        "columns": [
          "command",
          "what it does"
        ],
        "density": "compact",
        "rows": [
          [
            "render <path>",
            "Renders a bundle to agent-readable markdown. An agent never parses doc.json directly."
          ],
          [
            "grep <term> [pathPrefix]",
            "Searches across bundles."
          ],
          [
            "backlinks rescan [docsRoot]",
            "Rebuilds the derived docs-index database."
          ],
          [
            "links check [docsRoot]",
            "Checks reference integrity and exits non-zero on broken references."
          ],
          [
            "audit [docsRoot]",
            "Machine-checks corpus structural standards. Errors (numbering, missing parent docs, invalid doc.json) exit non-zero; warnings are informational."
          ],
          [
            "migrate [repoRoot]",
            "Migrates markdown to bundles non-destructively by default, writing doc.json alongside .mdx sources. Deletion requires both --retire-twins and --yes-delete-markdown."
          ],
          [
            "serve",
            "Runs the workbench as a static SPA, or with --dev for HMR."
          ],
          [
            "export --out <dir>",
            "Produces a fully static read-only site."
          ]
        ],
        "title": "Command surface"
