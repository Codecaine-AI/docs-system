    "b-60-docs-cli-lead-2": {
      "id": "b-60-docs-cli-lead-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "@codecaine-ai/docs-cli",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is the executable dialect for agents, humans, and repository automation. Its "
        },
        {
          "insert": "docs-cli",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " binary turns document reading, discovery, integrity checks, migration, local serving, and static export into stable process calls. The package is a leaf entry point over docs-model, docs-index, and docs-workbench rather than a new document or server authority."
        }
      ],
      "children": []
    },
