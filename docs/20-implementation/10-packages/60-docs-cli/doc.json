    "b-60-docs-cli-command-table-4": {
      "id": "b-60-docs-cli-command-table-4",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "render",
            "description": "Resolve a bundle, validate doc.json, and render agent-readable Markdown.",
            "params": [
              {
                "name": "path",
                "type": "string",
                "required": true,
                "description": "Bundle directory, explicit doc.json, bare *.doc.json, or docs-relative bundle path."
              }
            ],
            "returns": "Markdown on stdout; exit 1 on resolution, parse, or validation failure"
          },
          {
            "name": "grep",
            "description": "Render bundles and search their Markdown line by line, case-insensitively.",
            "params": [
              {
                "name": "term",
                "type": "string",
                "required": true
              },
              {
                "name": "pathPrefix",
                "type": "string",
                "required": false,
                "description": "Search root; defaults to docs."
              }
            ],
            "returns": "path:line: text rows plus a match count"
          },
          {
            "name": "backlinks rescan",
            "description": "Rebuild the derived backlinks database from documents and canvas sidecars.",
            "params": [
              {
                "name": "docsRoot",
                "type": "string",
                "required": false,
                "description": "Defaults to ./docs."
              }
            ],
            "returns": "Database path and scan totals"
          },
          {
            "name": "links check",
            "description": "Rescan references, then verify document targets and repository-relative source targets.",
            "params": [
              {
                "name": "docsRoot",
                "type": "string",
                "required": false,
                "description": "Defaults to ./docs."
              }
            ],
            "returns": "Stale references; exit 1 when any remain"
          },
          {
            "name": "audit",
            "description": "Check numbering, parent-document structure, bundle validity, title count, image alt text, and opening paragraphs.",
            "params": [
              {
                "name": "docsRoot",
                "type": "string",
                "required": false,
                "description": "Defaults to ./docs."
              }
            ],
            "returns": "Findings; structural errors exit 1 and warnings exit 0"
          },
          {
            "name": "migrate",
            "description": "Convert Markdown-family source files into folder bundles and write a migration report.",
            "params": [
              {
                "name": "repoRoot",
                "type": "string",
                "required": false,
                "description": "Discovered upward from the current directory when omitted."
              },
              {
                "name": "--drafts",
                "type": "flag",
                "required": false,
                "description": "Include docs/.drafts, which is exempt by default."
              },
              {
                "name": "--retire-twins",
                "type": "flag",
                "required": false,
                "description": "Select the separate Markdown-twin deletion branch."
              },
              {
                "name": "--yes-delete-markdown",
                "type": "flag",
                "required": false,
                "description": "Required confirmation for a real retirement."
              },
              {
                "name": "--dry-run",
                "type": "flag",
                "required": false,
                "description": "Preview retirement; the ordinary migration branch does not consume this flag."
              }
            ],
            "returns": "Migration report file for conversion or JSON stdout for retirement; exit 1 on conversion failures or missing deletion confirmation"
          },
          {
            "name": "serve",
            "description": "Run the workbench API and SPA against a selected docs root.",
            "params": [
              {
                "name": "--root",
                "type": "path",
                "required": false,
                "description": "Defaults to docs."
              },
              {
                "name": "--port",
                "type": "integer",
                "required": false,
                "description": "API or combined-server port; defaults to 4800."
              },
              {
                "name": "--ui-port",
                "type": "integer",
                "required": false,
                "description": "Optional fixed Vite port in development mode."
              },
              {
                "name": "--host",
                "type": "string",
                "required": false,
                "description": "Bind address; defaults to loopback."
              },
              {
                "name": "--dev / --rebuild / --theme-locked",
                "type": "flags",
                "required": false
              }
            ],
            "returns": "Long-running workbench process"
          },
          {
            "name": "export",
            "description": "Build a read-only static workbench and its data snapshots.",
            "params": [
              {
                "name": "--root",
                "type": "path",
                "required": false,
                "description": "Defaults to docs."
              },
              {
                "name": "--out",
                "type": "path",
                "required": true
              },
              {
                "name": "--rebuild",
                "type": "flag",
                "required": false
              }
            ],
            "returns": "JSON export report; exit 1 when bundle failures occur"
          }
        ],
        "title": "docs-cli"
      },
      "children": []
    },
