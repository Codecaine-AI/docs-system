      "type": "callout",
      "props": {
        "kind": "Decision",
        "title": "The command dialect is durable",
        "tone": "decision"
      },
      "text": [
        {
          "insert": "Agents read with "
        },
        {
          "insert": "docs-cli render",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", discover with "
        },
        {
          "insert": "docs-cli grep",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", and gate reference integrity with "
        },
        {
          "insert": "docs-cli links check",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". Command names, arguments, stdout, and exit behavior must remain scriptable while the app shell evolves. That requirement applies whether the executable remains a separate package or moves into workbench."
        }
      ],
      "children": []
    },
    "b-60-docs-cli-boundary-review-11": {
      "id": "b-60-docs-cli-boundary-review-11",
      "type": "callout",
      "props": {
        "kind": "Open call",
        "title": "docs-cli may merge into docs-workbench",
        "tone": "info"
      },
      "text": [
        {
          "insert": "The package split is a judgment call. "
        },
        {
          "insert": "docs-cli",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " already declares "
        },
        {
          "insert": "@codecaine-ai/docs-workbench",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " as a dependency, and "
        },
        {
          "insert": "serve",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and "
        },
        {
          "insert": "export",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " delegate directly to it. Dynamic imports defer app loading, but the install graph is not isolated. Keeping the package preserves a named executable surface for command-only use; merging it could simplify distribution without changing that surface. No runtime incompatibility settles the choice."
        }
      ],
      "children": []
    },
