    "b-fw2-surface-lead-14": {
      "id": "b-fw2-surface-lead-14",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The public surface is content addressed through the skill loader, not JavaScript exports. "
        },
        {
          "insert": "packages/framework/SKILL.md",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/framework/SKILL.md"
            }
          }
        },
        {
          "insert": " accepts a task, classifies it as navigate, produce, or maintain, then names the relative file key to load with "
        },
        {
          "insert": "skill_read",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". The operations below describe that routing contract; they are not executable functions or CLI commands."
        }
      ],
      "children": []
    },
    "b-fw2-surface-ops-15": {
      "id": "b-fw2-surface-ops-15",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "navigate",
            "description": "Research the documented system, narrow by SCAN/SKIM/READ, and follow implementation references into code only as needed.",
            "params": [
              {
                "name": "task",
                "type": "research | understand | locate",
                "required": true,
                "description": "A request to understand the existing system."
              }
            ],
            "returns": "10-cookbook/10-navigate.md"
          },
          {
            "name": "produce",
            "description": "Create documentation for a new project, feature, component, or significant addition.",
            "params": [
              {
                "name": "task",
                "type": "create | document-new",
                "required": true,
                "description": "A request that adds new documented surface."
              }
            ],
            "returns": "10-cookbook/20-produce.md → scaffold, interview, write, annotate"
          },
          {
            "name": "maintain",
            "description": "Bring existing documentation back into alignment and verify its health.",
            "params": [
              {
                "name": "task",
                "type": "fix | refactor | update | audit",
                "required": true,
                "description": "A request that changes or checks an existing documented area."
              }
            ],
            "returns": "10-cookbook/30-maintain.md → write, audit"
          }
        ],
        "title": "docs-framework — intent routing"
      },
      "children": []
