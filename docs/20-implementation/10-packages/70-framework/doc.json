    "b-fw2-intro-2": {
      "id": "b-fw2-intro-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "@codecaine-ai/docs-framework-skill",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is the agent-loadable operational manual for navigating, producing, and maintaining a docs corpus. It contains no runtime source: a "
        },
        {
          "insert": "SKILL.md",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " entry point routes authoring intent into cookbooks, standards, workflows, templates, and setup guidance. The package exists to deliver that methodology to host repositories; a running docs installation does not load it."
        }
      ],
      "children": []
    },
    "b-fw2-package-heading-7": {
      "id": "b-fw2-package-heading-7",
      "type": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "Why It Is a Package at All"
        }
      ],
      "children": []
    },
    "b-fw2-package-para-8": {
      "id": "b-fw2-package-para-8",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The distribution boundary exists for convenience. Workspace packaging makes the methodology resolvable and versionable, while the mount described in "
        },
        {
          "insert": "packages/framework/99-appendix/10-setup-guide.md",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/framework/99-appendix/10-setup-guide.md"
            }
          }
        },
        {
          "insert": " lets host repositories pin the docs-system checkout and symlink agent skill directories to this package. Those are delivery properties, not a runtime boundary."
        }
      ],
      "children": []
    },
    "b-fw2-manifest-11": {
      "id": "b-fw2-manifest-11",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "packages/framework/package.json",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/framework/package.json"
            }
          }
        },
        {
          "insert": " makes the narrow boundary literal: it declares only the private workspace name and version. It has no "
        },
        {
          "insert": "main",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "exports",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "bin",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", scripts, or dependency fields."
        }
      ],
      "children": []
    },
    "b-fw2-odd-35": {
      "id": "b-fw2-odd-35",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "This makes framework the odd one out under "
        },
        {
          "insert": "packages/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". The neighboring packages expose libraries, an executable command surface, or a runnable application; framework is versioned content. Its package line names a delivery unit rather than a runtime boundary."
        }
      ],
      "children": []
    },
    "b-fw2-boundary-callout-9": {
      "id": "b-fw2-boundary-callout-9",
      "type": "callout",
      "props": {
        "kind": "Open call",
        "title": "Framework Packaging",
        "tone": "info"
      },
      "text": [
        {
          "insert": "Framework-as-package remains a judgment call. Plain repository content or a dedicated skill distribution channel could replace this boundary without changing the runtime architecture; the current package earns its place only through resolving, versioning, and symlinking convenience."
        }
      ],
      "children": []
    },
