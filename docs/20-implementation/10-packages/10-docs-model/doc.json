          "insert": "updateBlock",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " validate the resulting props object against its compiled checker, so unknown stored keys fail the closed schema even when an edit only touches text. Action parameter schemas are not required to be closed; local action dispatch ignores and discards stray parameters. "
        },
        {
          "insert": "packages/docs-model/src/components/__tests__/schema-over-corpus.test.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-model/src/components/__tests__/schema-over-corpus.test.ts"
            }
          }
        },
        {
          "insert": " applies every registered state schema to repository documents, while full-document validation remains a separate structural gate. This split keeps structural reads tolerant while registered mutation checks reject undeclared state."
        }
      ],
      "children": []
    },
