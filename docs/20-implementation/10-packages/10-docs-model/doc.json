              "kind": "source",
              "path": "packages/docs-model/src/components/validate.ts"
            }
          }
        },
        {
          "insert": " compiles a static state-schema registry for every component-owned block type in the mutation path. "
        },
        {
          "insert": "insertBlock",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and "
