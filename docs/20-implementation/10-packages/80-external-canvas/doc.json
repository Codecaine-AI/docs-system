    "b-80-external-canvas-identity-2": {
      "id": "b-80-external-canvas-identity-2",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Canvas and Sequence are independent projects mounted in the docs-system repository as git submodules. The docs system consumes their document schemas, agent-operation descriptors, and renderers, and integrates with their standalone authoring applications without owning those implementations. This page describes the boundary mechanics, with Canvas as the complete integration and Sequence as the parallel but narrower case."
        }
      ],
      "children": []
    },
    "b-80-external-canvas-location-heading-5": {
      "id": "b-80-external-canvas-location-heading-5",
