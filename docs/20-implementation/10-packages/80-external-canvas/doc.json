      "id": "b-80-external-canvas-surface",
      "type": "interaction-surface",
      "props": {
        "operations": [
          {
            "name": "canvas block reference",
            "description": "doc.json stores canvasId or src plus optional view and title; engine state stays in the canvas document.",
            "kind": "query",
            "returns": "an external canvas identity and optional crop"
          },
          {
            "name": "canvas.*",
            "description": "docs-model lifts the external agent-schema descriptors into forwarded component actions.",
            "kind": "action",
            "returns": "a request for the canvas authority"
          },
          {
            "name": "GET /api/canvas?src=",
            "description": "Reads one docs-root-relative sidecar and returns its bytes hash with the parsed payload.",
            "kind": "query",
            "returns": "canvas_path, content_hash, canvas"
          },
          {
            "name": "PUT /api/canvas",
            "description": "Saves an existing sidecar with original_hash conflict protection; Canvas Studio uses the src-rooted form.",
            "kind": "action",
            "returns": "the new content_hash or a 409 conflict"
          },
          {
            "name": "DocsClientProvider.canvasEmbed",
            "description": "The viewer asks the host to render a canonicalized canvas reference without importing the engine.",
            "kind": "query",
            "returns": "a host-owned React embed"
          },
          {
            "name": "Canvas Studio ?src=&server=",
            "description": "Studio can open a repository sidecar directly; server is optional and otherwise comes from persisted or default configuration.",
            "kind": "action",
            "returns": "the standalone canvas editor"
          }
        ],
        "title": "Canvas seams"
