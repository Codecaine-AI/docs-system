          "insert": "Why They Live Under external/, Not packages/"
        }
      ],
      "children": []
    },
    "b-80-external-canvas-ownership-boundary-6": {
      "id": "b-80-external-canvas-ownership-boundary-6",
      "type": "callout",
      "props": {
        "kind": "Boundary",
        "title": "The layout makes ownership literal",
        "tone": "decision"
      },
      "text": [
        {
          "insert": "Canvas and Sequence have their own repositories, workspaces, package surfaces, and application code. Mounting them under "
        },
        {
          "insert": "external/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " records that the docs system supports them but does not own them. Moving either project into "
        },
        {
          "insert": "packages/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " would falsely assign its engine and editor to the docs-system package graph."
        }
      ],
      "children": []
    },
