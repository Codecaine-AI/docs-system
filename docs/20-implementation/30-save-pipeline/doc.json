    "b-10-save-pipeline-when-an-sse-event-flashe-17": {
      "id": "b-10-save-pipeline-when-an-sse-event-flashe-17",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "When an SSE event flashes changed blocks, the read surfaces get a "
        },
        {
          "insert": "data-docs-changed",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " attribute set on the block's wrapper element. Inside the editor that approach cannot work: ProseMirror owns the contenteditable DOM and strips foreign attribute mutations as drift. The editor therefore renders the flash as a ProseMirror "
        },
        {
          "insert": "node decoration",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " from "
        },
        {
          "insert": "packages/docs-viewer/src/editor/decorations/changed-flash.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-viewer/src/editor/decorations/changed-flash.ts"
            }
          }
        },
        {
          "insert": " driven by the same highlighted-id set — same CSS animation, different mechanism."
        }
      ],
      "children": []
    },
