    "b-10-save-pipeline-on-save-debounce-fire-6": {
      "id": "b-10-save-pipeline-on-save-debounce-fire-6",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "On save (debounce fire, "
        },
        {
          "insert": "Cmd+S",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", blur, or unmount), the editor calls "
        },
        {
          "insert": "pmToDoc",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "diffToOps",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " in "
        },
        {
          "insert": "packages/docs-viewer/src/editor/core/convert.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-viewer/src/editor/core/convert.ts"
            }
          }
        },
        {
          "insert": ": the current ProseMirror JSON becomes a "
        },
        {
          "insert": "DocDocument",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and is diffed against "
        },
        {
          "insert": "baseDocRef.current",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " into a "
        },
        {
          "insert": "DocOp[]",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " batch. The diff is a small batch of the model's six generic structural/text ops; the vocabulary's seventh op, "
        },
        {
          "insert": "componentAction",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", is the typed-action bridge for agents and lives in "
        },
        {
          "insert": "the mutation model — ops, inverses, undo",
          "attributes": {
            "reference": {
              "kind": "doc",
              "path": "10-system-design/30-data-model/50-mutation-model"
            }
          }
        },
        {
          "insert": "; the editor's diff never emits it. A no-op edit diffs to zero ops and no request is sent."
        }
      ],
      "children": []
    },
