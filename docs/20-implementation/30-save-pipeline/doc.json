    "b-10-save-pipeline-doceditor-hosts-a-tipt-4": {
      "id": "b-10-save-pipeline-doceditor-hosts-a-tipt-4",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "DocEditor",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " in "
        },
        {
          "insert": "packages/docs-viewer/src/editor/DocEditor.tsx",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-viewer/src/editor/DocEditor.tsx"
            }
          }
        },
        {
          "insert": " hosts a TipTap/ProseMirror editor whose node schema in "
        },
        {
          "insert": "packages/docs-viewer/src/editor/core/schema.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/docs-viewer/src/editor/core/schema.ts"
            }
          }
        },
        {
          "insert": " mirrors the doc.json block types one-to-one. Every ProseMirror node carries the block's stable id in its attrs, so a block edited in place keeps its identity — that is what lets the diff below emit a single "
