            "code": true
          }
        },
        {
          "insert": " — a strict route backed by "
        },
        {
          "insert": "uploadDocVideoAsset",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " with a 64 MB cap, an extension/MIME allowlist ("
        },
        {
          "insert": "mp4",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "webm",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "mov",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "m4v",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "video/*",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "), and collision-suffixed filenames under the bundle's "
        },
        {
          "insert": "assets/videos/",
          "attributes": {
            "code": true
          }
