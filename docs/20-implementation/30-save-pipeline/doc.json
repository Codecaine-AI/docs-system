          "insert": "DocPage",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", then "
        },
        {
          "insert": "uploadVideoAsset",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " POSTs it (multipart) to "
