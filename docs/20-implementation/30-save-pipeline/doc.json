    "b-10-save-pipeline-the-editor-adopts-the-se-15": {
      "id": "b-10-save-pipeline-the-editor-adopts-the-se-15",
      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The editor adopts the server's returned doc as the next diff baseline. The host feeds that same object back down as the "
        },
        {
          "insert": "document",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " prop, and the editor recognizes the identity and "
        },
        {
          "insert": "skips",
          "attributes": {
            "italic": true
          }
        },
        {
          "insert": " re-seeding its content — this is why a save never resets your cursor. If keystrokes landed while the save was in flight, the doc simply stays dirty and the next debounce saves the remainder against the new baseline."
        }
      ],
      "children": []
    },
