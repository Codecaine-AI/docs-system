      "type": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "From the client side, "
        },
        {
          "insert": "409",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and "
        },
        {
          "insert": "423",
          "attributes": {
            "code": true
